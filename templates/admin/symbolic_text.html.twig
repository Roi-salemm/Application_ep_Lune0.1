{# Page admin Symbolic Text.
   Pourquoi: visualiser une timeline dynamique et piloter le CRUD des textes relies a sw_display/sw_content/sw_schedule.
   Info: toute la timeline est affichee en UTC et alignee temporellement. #}
{% extends 'admin/base.html.twig' %}

{% set page_title = page_title|default('Symbolic Text') %}
{% set page_subtitle = page_subtitle|default('Edition timeline UTC') %}
{% set active_menu = active_menu|default('symbolic_text') %}
{% set now_ts = "now"|date('U') %}

{% block admin_content %}
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="admin-flash admin-flash--{{ label }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <section class="admin-card symbolic-text-card">
        <div class="admin-card__header">
            <h2 class="admin-card__title">Symbolic Text timeline</h2>
            <p class="admin-card__subtitle" data-window-label>
                Fenetre UTC: {{ window_start_utc|date('Y-m-d H:i') }} -> {{ window_end_utc|date('Y-m-d H:i') }}
            </p>
        </div>

        <div class="symbolic-text-toolbar">
            <div class="symbolic-text-toolbar__group">
                {% for span_key in span_options %}
                    <a class="symbolic-span-btn {{ span_key == span ? 'is-active' : '' }}"
                       href="{{ path('admin_symbolic_text', {'span': span_key, 'end_utc': window_end_input, 'lang': lang, 'show_all': show_all ? 1 : 0}) }}">{{ span_key }}</a>
                {% endfor %}
                <button type="button" class="symbolic-span-btn symbolic-span-btn--today" data-jump-today>Aujourd'hui</button>
                {% for lang_code, lang_label in lang_options %}
                    <a class="symbolic-span-btn {{ lang_code == lang ? 'is-active' : '' }}"
                       href="{{ path('admin_symbolic_text', {'span': span, 'end_utc': window_end_input, 'lang': lang_code, 'show_all': show_all ? 1 : 0}) }}">{{ lang_label }}</a>
                {% endfor %}
                <a class="symbolic-span-btn {{ not show_all ? 'is-active' : '' }}"
                   href="{{ path('admin_symbolic_text', {'span': span, 'end_utc': window_end_input, 'lang': lang, 'show_all': 0}) }}">Publies</a>
                <a class="symbolic-span-btn {{ show_all ? 'is-active' : '' }}"
                   href="{{ path('admin_symbolic_text', {'span': span, 'end_utc': window_end_input, 'lang': lang, 'show_all': 1}) }}">Tous</a>
            </div>
            {% if show_all %}
                <div class="symbolic-text-toolbar__actions">
                    <button type="button"
                            class="admin-button admin-button--primary symbolic-bulk-save"
                            data-bulk-save
                            disabled>
                        Sauvegarder <span class="symbolic-bulk-save__count" data-bulk-count>0</span>
                    </button>
                </div>
            {% endif %}
            <div class="symbolic-text-toolbar__meta">UTC</div>
        </div>

        <div class="symbolic-layout">
            <aside class="symbolic-layout__labels" aria-label="Lignes timeline">
                <div class="symbolic-label-groups" aria-hidden="true">
                    <span class="symbolic-label-group symbolic-label-group--symbolic-all" data-label-group="symbolic-all"></span>
                    <span class="symbolic-label-group symbolic-label-group--family-weather" data-label-group="family-weather"></span>
                    <span class="symbolic-label-group symbolic-label-group--event-stack" data-label-group="event-stack"></span>
                </div>
                <div class="symbolic-label" data-label-row="real">Temps</div>
                <div class="symbolic-label" data-label-row="astronomy">Astronomie</div>
                <div class="symbolic-label symbolic-label--thin" data-label-row="lunation">Lune annee</div>
                <div class="symbolic-label symbolic-label--compact" data-label-row="family_symbolic">Family Symbolic</div>
                <div class="symbolic-label symbolic-label--compact" data-label-row="weather_parse">Weather parse</div>
                <div class="symbolic-label symbolic-label--compact" data-label-row="weather">Weather</div>
                <div class="symbolic-label symbolic-label--compact" data-label-row="event_group">Evenement :</div>
                <div class="symbolic-label symbolic-label--sub symbolic-label--compact" data-label-row="influence_stellar">astronomical event</div>
                <div class="symbolic-label symbolic-label--sub symbolic-label--compact symbolic-label--synodic" data-label-row="influence_synodic">influence</div>
                <div class="symbolic-label symbolic-label--sub symbolic-label--compact" data-label-row="appellation">lunationName</div>
            </aside>

            <div class="symbolic-layout__timeline"
                 data-timeline-wheel
                 data-api-url="{{ path('admin_symbolic_text_data') }}"
                 data-toggle-active-url="{{ path('admin_symbolic_text_bulk_active') }}"
                 data-toggle-active-token="{{ csrf_token('symbolic_text_bulk_active') }}"
                 data-impact-check-url="{{ path('admin_symbolic_text_impact_check') }}"
                 data-impact-check-token="{{ csrf_token('symbolic_text_impact_check') }}"
                 data-span="{{ span }}"
                 data-span-seconds="{{ span_seconds }}"
                 data-lang="{{ lang }}"
                 data-show-all="{{ show_all ? '1' : '0' }}"
                 data-window-end-ts="{{ window_end_ts }}">
                <div class="symbolic-grid" data-grid-lines>
                    {% for marker in day_markers %}
                        <span class="symbolic-grid__line" style="left: {{ marker.left }}%;"></span>
                    {% endfor %}
                </div>

                <div class="symbolic-track symbolic-track--real" data-track-real data-track-row-id="real">
                    {% for segment in real_segments %}
                        <div class="symbolic-real-cell" style="left: {{ segment.left }}%; width: {{ segment.width }}%;">
                            {{ segment.label }}
                        </div>
                    {% endfor %}
                </div>

                <div class="symbolic-track symbolic-track--astronomy" data-track-astronomy data-track-row-id="astronomy">
                    {% if astronomy_points is empty %}
                        <div class="symbolic-track__empty">Aucun evenement de phase dans cette fenetre.</div>
                    {% else %}
                        {% for point in astronomy_points %}
                            <div class="symbolic-astro-point phase-{{ point.phase }}" style="left: {{ point.left }}%;">
                                <span class="symbolic-astro-point__dot"></span>
                                <span class="symbolic-astro-point__label">{{ point.label }}</span>
                                <span class="symbolic-astro-point__time">{{ point.time_label }}</span>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="symbolic-track symbolic-track--lunation" data-track-lunation data-track-row-id="lunation">
                    {% set lunation_segments_safe = lunation_segments|default([]) %}
                    {% if lunation_segments_safe is empty %}
                        <div class="symbolic-track__empty">Lunaisons indisponibles dans cette fenetre.</div>
                    {% else %}
                        {% for segment in lunation_segments_safe %}
                            <div class="symbolic-lunation-segment"
                                 style="left: {{ segment.left }}%; width: {{ segment.width }}%; --lunation-color: {{ segment.color }};"
                                 title="{{ segment.label }} - {{ segment.year }} ({{ segment.full_start_ts|date('Y-m-d H:i', 'UTC') }} -> {{ segment.full_end_ts|date('Y-m-d H:i', 'UTC') }} UTC)">
                                <span>{{ segment.label }}</span>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="symbolic-track symbolic-track--symbolic" data-track-symbolic data-track-row-id="family_symbolic">
                    {% if symbolic_segments is empty %}
                        <div class="symbolic-track__empty">Influence symbolique indisponible (orb_window influence_orb / midpoint_partition_v1 absent).</div>
                    {% else %}
                        {% for segment in symbolic_segments %}
                            <div class="symbolic-phase-band"
                                style="left: {{ segment.left }}%; width: {{ segment.width }}%; --phase-color: {{ segment.color }};"
                                data-symbolic-key="{{ segment.full_start_ts ~ '-' ~ segment.full_end_ts ~ '-' ~ segment.label }}"
                                data-phase-label="{{ segment.label|e('html_attr') }}"
                                data-phase-start="{{ segment.full_start_ts }}"
                                data-phase-end="{{ segment.full_end_ts }}">
                                <span>{{ segment.label }}</span>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="symbolic-track symbolic-track--parse"
                     data-track-weather-parse
                     data-track-row-id="weather_parse"
                     data-parse-action="{{ path('admin_symbolic_text_parse_weather_week') }}"
                     data-parse-token="{{ csrf_token('parse_symbolic_text_weather_week') }}"></div>

                <div class="symbolic-track symbolic-track--content symbolic-track--weather" data-track-weather data-track-row-id="weather"></div>

                <div class="symbolic-track symbolic-track--event-group" data-track-row-id="event_group" aria-hidden="true"></div>

                {% for row in row_definitions %}
                    {% if row.code == 'influence_synodic' %}
                        <div class="symbolic-track symbolic-track--synodic"
                             data-track-synodic
                             data-track-row-id="{{ row.code }}"
                             data-display-code="{{ row.code }}"></div>
                    {% else %}
                        {% set entries = entries_by_row[row.code]|default([]) %}
                        {% set gaps = gaps_by_row[row.code]|default([]) %}
                        <div class="symbolic-track symbolic-track--content"
                             data-row-code="{{ row.code }}"
                             data-track-row-id="{{ row.code }}"
                             data-track-row="{{ row.code }}"
                             data-row-schedule-type="{{ row.schedule_type }}">
                            {% for gap in gaps %}
                                <button type="button"
                                        class="symbolic-gap-add"
                                        style="left: {{ gap.center }}%;"
                                        title="Ajouter un texte"
                                        data-open-create
                                        data-display-code="{{ row.code }}"
                                        data-schedule-type="{{ row.schedule_type }}"
                                        data-start="{{ gap.start_at_input }}"
                                        data-end="{{ gap.end_at_input }}">+</button>
                            {% endfor %}

                            {% if entries is empty %}
                                <div class="symbolic-track__empty symbolic-track__empty--warning">! Donnee manquante sur cette ligne</div>
                            {% endif %}

                            {% for entry in entries %}
                                <article class="symbolic-entry {{ entry.is_ready ? (entry.end_ts <= now_ts ? 'is-ready-past' : 'is-ready-upcoming') : 'is-warning' }}"
                                         style="left: {{ entry.left }}%; width: {{ entry.width }}%; --entry-color: {{ entry.color }};">
                                    <div class="symbolic-entry__text">
                                        <strong>{{ entry.label }}</strong>
                                        {% if entry.subtitle %}
                                            <small>{{ entry.subtitle }}</small>
                                        {% endif %}
                                    </div>
                                    {% if show_all %}
                                        <label class="symbolic-publish-switch symbolic-publish-switch--compact"
                                               title="Publication snapshot (sw_display.is_active)">
                                            <input type="checkbox"
                                                   class="symbolic-publish-switch__input"
                                                   data-publish-toggle
                                                   data-schedule-id="{{ entry.id }}"
                                                   data-original-active="{{ entry.is_published_for_snapshot ? '1' : '0' }}"
                                                   {% if entry.is_published_for_snapshot %}checked{% endif %}>
                                            <span class="symbolic-publish-switch__slider"></span>
                                            <span class="symbolic-publish-switch__label">
                                                {{ entry.is_published_for_snapshot ? 'Publie' : 'Non publie' }}
                                            </span>
                                        </label>
                                    {% endif %}
                                    <button type="button"
                                            class="symbolic-entry__edit"
                                            data-open-edit
                                            data-id="{{ entry.id }}"
                                            data-display-code="{{ row.code }}"
                                            data-label="{{ entry.label|e('html_attr') }}"
                                            data-subtitle="{{ entry.subtitle|default('')|e('html_attr') }}"
                                            data-color="{{ entry.color|e('html_attr') }}"
                                            data-icon="{{ entry.icon|default('')|e('html_attr') }}"
                                            data-start="{{ entry.start_at_input }}"
                                            data-end="{{ entry.end_at_input }}"
                                            data-priority="{{ entry.priority }}"
                                            data-schedule-type="{{ entry.schedule_type|e('html_attr') }}"
                                            data-status="{{ entry.status|e('html_attr') }}"
                                            data-schema-version="{{ entry.schema_version|e('html_attr') }}"
                                            data-comment="{{ entry.comment|default('')|e('html_attr') }}"
                                            data-editorial-notes="{{ entry.editorial_notes|default('')|e('html_attr') }}"
                                            data-payload-json="{{ entry.payload_json|default('')|e('html_attr') }}"
                                            data-is-published="{{ entry.is_published ? '1' : '0' }}"
                                            data-is-validated="{{ entry.is_validated ? '1' : '0' }}"
                                            data-is-current="{{ entry.is_current ? '1' : '0' }}"
                                            data-update-token="{{ csrf_token('update_symbolic_text_' ~ entry.id) }}"
                                            data-delete-token="{{ csrf_token('delete_symbolic_text_' ~ entry.id) }}">Modifier</button>
                                </article>
                            {% endfor %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        </div>
    </section>

    <div class="admin-modal" data-symbolic-create-modal aria-hidden="true">
        <div class="admin-modal__backdrop" data-modal-close></div>
        <div class="admin-modal__dialog admin-modal__dialog--wide" role="dialog" aria-modal="true">
            <div class="admin-modal__header">Ajouter un texte timeline</div>
            {{ form_start(create_form, {'attr': {'class': 'admin-modal__body admin-form', 'data-create-form': '1'}}) }}
                <input type="hidden" name="span" value="{{ span }}">
                <input type="hidden" name="end_utc" value="{{ window_end_input }}" data-window-end-hidden>
                <input type="hidden" name="lang" value="{{ lang }}" data-window-lang-hidden>
                <input type="hidden" name="show_all" value="{{ show_all ? '1' : '0' }}" data-window-show-all-hidden>

                <div class="admin-form__section">
                    <div class="admin-form__label">SW Display</div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Ligne</span>
                            {{ form_widget(create_form.row_code) }}
                            {{ form_errors(create_form.row_code) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Lang</span>
                            {{ form_widget(create_form.display_lang) }}
                            {{ form_errors(create_form.display_lang) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Comment</span>
                            {{ form_widget(create_form.display_comment) }}
                            {{ form_errors(create_form.display_comment) }}
                        </label>
                    </div>
                    <div class="admin-form__row symbolic-checks">
                        <label>{{ form_widget(create_form.display_is_active) }} is_active</label>
                        {{ form_errors(create_form.display_is_active) }}
                    </div>
                </div>

                <div class="admin-form__section">
                    <div class="admin-form__label">SW Content</div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Texte</span>
                            {{ form_widget(create_form.label) }}
                            {{ form_errors(create_form.label) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Sous-texte</span>
                            {{ form_widget(create_form.subtitle) }}
                            {{ form_errors(create_form.subtitle) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Couleur (#RRGGBB)</span>
                            {{ form_widget(create_form.color) }}
                            {{ form_errors(create_form.color) }}
                        </label>
                    </div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Icone</span>
                            {{ form_widget(create_form.icon) }}
                            {{ form_errors(create_form.icon) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Status</span>
                            {{ form_widget(create_form.status) }}
                            {{ form_errors(create_form.status) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Schema version</span>
                            {{ form_widget(create_form.schema_version) }}
                            {{ form_errors(create_form.schema_version) }}
                        </label>
                    </div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Editorial notes</span>
                            {{ form_widget(create_form.editorial_notes) }}
                            {{ form_errors(create_form.editorial_notes) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Content JSON (IA / humain)</span>
                            {{ form_widget(create_form.content_json) }}
                            {{ form_errors(create_form.content_json) }}
                        </label>
                    </div>
                    <div class="admin-form__row symbolic-checks">
                        <label>{{ form_widget(create_form.content_is_current) }} is_current</label>
                        <label>{{ form_widget(create_form.content_is_validated) }} is_validated</label>
                    </div>
                </div>

                <div class="admin-form__section">
                    <div class="admin-form__label">SW Schedule</div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Start at UTC</span>
                            {{ form_widget(create_form.starts_at_utc) }}
                            {{ form_errors(create_form.starts_at_utc) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">End at UTC</span>
                            {{ form_widget(create_form.ends_at_utc) }}
                            {{ form_errors(create_form.ends_at_utc) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Priorite</span>
                            {{ form_widget(create_form.priority) }}
                            {{ form_errors(create_form.priority) }}
                        </label>
                    </div>
                    <div class="admin-form__row">
                        <label class="admin-form__field">
                            <span class="admin-form__label">Schedule comment</span>
                            {{ form_widget(create_form.schedule_comment) }}
                            {{ form_errors(create_form.schedule_comment) }}
                        </label>
                        <label class="admin-form__field">
                            <span class="admin-form__label">Payload JSON</span>
                            {{ form_widget(create_form.payload_json) }}
                            {{ form_errors(create_form.payload_json) }}
                        </label>
                    </div>
                    <div class="admin-form__row symbolic-checks">
                        <label>{{ form_widget(create_form.schedule_is_published) }} is_published</label>
                    </div>
                </div>

                {{ form_rest(create_form) }}
                <div class="admin-modal__actions">
                    <button class="admin-button admin-button--primary" type="submit">Creer</button>
                    <button class="admin-button" type="button" data-modal-close>Annuler</button>
                </div>
            {{ form_end(create_form, {'render_rest': false}) }}
        </div>
    </div>

    <div class="admin-modal" data-symbolic-edit-modal aria-hidden="true">
        <div class="admin-modal__backdrop" data-modal-close></div>
        <div class="admin-modal__dialog admin-modal__dialog--wide" role="dialog" aria-modal="true">
            <div class="admin-modal__header">Modifier un texte timeline</div>
            <form class="admin-modal__body admin-form"
                  method="post"
                  data-edit-form
                  data-update-action-template="{{ path('admin_symbolic_text_update', {'id': 'SCHEDULE_ID'}) }}">
                <input type="hidden" name="_token" value="" data-edit-update-token>
                <input type="hidden" name="span" value="{{ span }}">
                <input type="hidden" name="end_utc" value="{{ window_end_input }}" data-window-end-hidden>
                <input type="hidden" name="lang" value="{{ lang }}" data-window-lang-hidden>
                <input type="hidden" name="show_all" value="{{ show_all ? '1' : '0' }}" data-window-show-all-hidden>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Ligne</span>
                        <select class="admin-form__select" name="display_code" data-edit-display-code required>
                            {% for row in row_definitions %}
                                <option value="{{ row.code }}">{{ row.label }}</option>
                            {% endfor %}
                        </select>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Texte</span>
                        <input class="admin-form__input" type="text" name="label" data-edit-label required>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Sous-texte</span>
                        <input class="admin-form__input" type="text" name="subtitle" data-edit-subtitle>
                    </label>
                </div>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Debut UTC</span>
                        <input class="admin-form__input" type="text" name="starts_at_utc" data-edit-start required>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Fin UTC</span>
                        <input class="admin-form__input" type="text" name="ends_at_utc" data-edit-end required>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Couleur</span>
                        <input class="admin-form__input" type="text" name="color" data-edit-color>
                    </label>
                </div>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Icone</span>
                        <input class="admin-form__input" type="text" name="icon" data-edit-icon>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Priorite</span>
                        <input class="admin-form__input" type="number" name="priority" data-edit-priority>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Type planning</span>
                        <select class="admin-form__select" name="schedule_type" data-edit-schedule-type>
                            <option value="influence_window">influence_window</option>
                            <option value="phase_window">phase_window</option>
                        </select>
                    </label>
                </div>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Statut</span>
                        <select class="admin-form__select" name="status" data-edit-status>
                            <option value="validated">validated</option>
                            <option value="review">review</option>
                            <option value="draft">draft</option>
                            <option value="archived">archived</option>
                        </select>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Schema version</span>
                        <input class="admin-form__input" type="text" name="schema_version" data-edit-schema-version>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Commentaire</span>
                        <input class="admin-form__input" type="text" name="comment" data-edit-comment>
                    </label>
                </div>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Notes editoriales</span>
                        <textarea class="admin-form__input" name="editorial_notes" rows="3" data-edit-editorial-notes></textarea>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Payload JSON</span>
                        <textarea class="admin-form__input" name="payload_json" rows="3" data-edit-payload-json></textarea>
                    </label>
                </div>

                <div class="admin-form__row symbolic-checks">
                    <label><input type="checkbox" name="is_published" value="1" data-edit-is-published> publie</label>
                    <label><input type="checkbox" name="is_validated" value="1" data-edit-is-validated> valide humain</label>
                    <label><input type="checkbox" name="is_current" value="1" data-edit-is-current> courant</label>
                </div>

                <div class="admin-modal__actions">
                    <button class="admin-button admin-button--primary" type="submit">Enregistrer</button>
                    <button class="admin-button" type="button" data-modal-close>Annuler</button>
                </div>
            </form>

            <form class="admin-modal__actions symbolic-delete-form"
                  method="post"
                  data-delete-form
                  data-delete-action-template="{{ path('admin_symbolic_text_delete', {'id': 'SCHEDULE_ID'}) }}">
                <input type="hidden" name="_token" value="" data-edit-delete-token>
                <input type="hidden" name="span" value="{{ span }}">
                <input type="hidden" name="end_utc" value="{{ window_end_input }}" data-window-end-hidden>
                <input type="hidden" name="lang" value="{{ lang }}" data-window-lang-hidden>
                <input type="hidden" name="show_all" value="{{ show_all ? '1' : '0' }}" data-window-show-all-hidden>
                <button class="admin-button admin-button--danger" type="submit">Supprimer</button>
            </form>
        </div>
    </div>

    <div class="admin-modal" data-symbolic-weather-zone-modal aria-hidden="true">
        <div class="admin-modal__backdrop" data-modal-close></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true">
            <div class="admin-modal__header">Parse Weather sur cette zone</div>
            <form class="admin-modal__body admin-form"
                  method="post"
                  action="{{ path('admin_symbolic_text_parse_weather_week') }}"
                  data-weather-zone-form>
                <input type="hidden" name="_token" value="{{ csrf_token('parse_symbolic_text_weather_week') }}">
                <input type="hidden" name="zone_start_utc" value="" data-weather-zone-start>
                <input type="hidden" name="zone_end_utc" value="" data-weather-zone-end>
                <input type="hidden" name="span" value="{{ span }}">
                <input type="hidden" name="end_utc" value="{{ window_end_input }}" data-window-end-hidden>
                <input type="hidden" name="lang" value="{{ lang }}" data-window-lang-hidden>
                <input type="hidden" name="show_all" value="{{ show_all ? '1' : '0' }}" data-window-show-all-hidden>

                <div class="admin-form__row">
                    <label class="admin-form__field">
                        <span class="admin-form__label">Phase key</span>
                        <select class="admin-form__select" name="phase_key" data-weather-zone-phase required>
                            <option value="0">0 (Nouvelle lune)</option>
                            <option value="1">1 (Premier croissant)</option>
                            <option value="2">2 (Premier quartier)</option>
                            <option value="3">3 (Gibbeuse croissante)</option>
                            <option value="4">4 (Pleine lune)</option>
                            <option value="5">5 (Gibbeuse decroissante)</option>
                            <option value="6">6 (Dernier quartier)</option>
                            <option value="7">7 (Dernier croissant)</option>
                        </select>
                    </label>
                    <label class="admin-form__field">
                        <span class="admin-form__label">Variant no</span>
                        <select class="admin-form__select" name="variant_no" data-weather-zone-variant required></select>
                    </label>
                </div>

                <div class="admin-form__row">
                    <div class="admin-form__field">
                        <span class="admin-form__label">Zone UTC</span>
                        <div class="admin-form__hint" data-weather-zone-range>n/a</div>
                    </div>
                </div>

                <div class="admin-modal__actions">
                    <button class="admin-button admin-button--primary" type="submit">Valider</button>
                    <button class="admin-button" type="button" data-modal-close>Annuler</button>
                </div>
            </form>
        </div>
    </div>

    <div class="admin-modal" data-symbolic-retro-confirm-modal aria-hidden="true">
        <div class="admin-modal__backdrop" data-retro-cancel></div>
        <div class="admin-modal__dialog" role="dialog" aria-modal="true">
            <div class="admin-modal__header">Validation requise: modification retroactive</div>
            <div class="admin-modal__body admin-form">
                <p class="admin-form__hint">
                    Cette modification touche une plage anterieure a aujourd hui (UTC).
                </p>
                <div class="admin-form__row">
                    <div class="admin-form__field">
                        <span class="admin-form__label">Plage UTC</span>
                        <div class="admin-form__hint" data-retro-range>n/a</div>
                    </div>
                    <div class="admin-form__field">
                        <span class="admin-form__label">Jours concernes</span>
                        <div class="admin-form__hint" data-retro-days>n/a</div>
                    </div>
                </div>
                <div class="admin-form__field">
                    <span class="admin-form__label">Impact de reecriture</span>
                    <div class="admin-form__hint" data-retro-overlap-summary>Aucun recouvrement detecte.</div>
                    <ul class="symbolic-retro-overlap-list" data-retro-overlap-list></ul>
                </div>
            </div>
            <div class="admin-modal__actions">
                <button class="admin-button admin-button--primary" type="button" data-retro-confirm>Valider</button>
                <button class="admin-button" type="button" data-retro-cancel>Annuler</button>
            </div>
        </div>
    </div>

    <script type="application/json" id="symbolic-initial-payload">{{ initial_payload|json_encode|raw }}</script>
    <script type="application/json" id="symbolic-weather-variants">{{ weather_variant_options|default([])|json_encode|raw }}</script>

    <script>
        (function () {
            var createModal = document.querySelector('[data-symbolic-create-modal]');
            var editModal = document.querySelector('[data-symbolic-edit-modal]');
            var weatherZoneModal = document.querySelector('[data-symbolic-weather-zone-modal]');
            var retroConfirmModal = document.querySelector('[data-symbolic-retro-confirm-modal]');
            var timelineRoot = document.querySelector('[data-timeline-wheel]');
            if (!createModal || !editModal || !weatherZoneModal || !retroConfirmModal || !timelineRoot) {
                return;
            }
            var impactCheckUrl = timelineRoot.getAttribute('data-impact-check-url') || '';
            var impactCheckToken = timelineRoot.getAttribute('data-impact-check-token') || '';
            var pendingRetroForm = null;
            var weatherVariantsNode = document.getElementById('symbolic-weather-variants');
            var weatherVariantOptions = [];
            if (weatherVariantsNode) {
                try {
                    weatherVariantOptions = JSON.parse(weatherVariantsNode.textContent || '[]');
                } catch (e) {
                    weatherVariantOptions = [];
                }
            }
            var weatherVariantsByPhase = {};
            weatherVariantOptions.forEach(function (item) {
                if (!item || typeof item.phase_key === 'undefined' || typeof item.variant_no === 'undefined') {
                    return;
                }
                var phase = parseInt(item.phase_key, 10);
                var variantNo = parseInt(item.variant_no, 10);
                if (Number.isNaN(phase) || Number.isNaN(variantNo) || phase < 0 || phase > 7 || variantNo < 1) {
                    return;
                }
                if (!weatherVariantsByPhase[phase]) {
                    weatherVariantsByPhase[phase] = [];
                }
                weatherVariantsByPhase[phase].push({
                    phase_key: phase,
                    variant_no: variantNo,
                    label: String(item.label || '').trim()
                });
            });
            Object.keys(weatherVariantsByPhase).forEach(function (phaseKey) {
                weatherVariantsByPhase[phaseKey].sort(function (a, b) {
                    return a.variant_no - b.variant_no;
                });
            });

            function escapeHtmlLocal(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function parsePhaseIndex(raw) {
                var value = String(raw || '').trim().toLowerCase();
                if (/^\d+$/.test(value)) {
                    var numeric = parseInt(value, 10);
                    return (numeric >= 0 && numeric <= 7) ? numeric : null;
                }
                if (value.indexOf('phase_') === 0) {
                    var tail = parseInt(value.slice(6), 10);
                    return Number.isNaN(tail) ? null : ((tail >= 0 && tail <= 7) ? tail : null);
                }
                var map = {
                    'new_moon': 0,
                    'waxing_crescent': 1,
                    'first_quarter': 2,
                    'waxing_gibbous': 3,
                    'full_moon': 4,
                    'waning_gibbous': 5,
                    'last_quarter': 6,
                    'waning_crescent': 7
                };
                return Object.prototype.hasOwnProperty.call(map, value) ? map[value] : null;
            }

            function openModal(modal) {
                modal.classList.add('is-open');
                modal.setAttribute('aria-hidden', 'false');
            }

            function closeModal(modal) {
                modal.classList.remove('is-open');
                modal.setAttribute('aria-hidden', 'true');
            }

            function closeAllModals() {
                closeModal(createModal);
                closeModal(editModal);
                closeModal(weatherZoneModal);
                closeModal(retroConfirmModal);
            }

            function parseUtcInputToTs(raw) {
                var value = String(raw || '').trim();
                if (value === '') {
                    return null;
                }
                var normalized = value.replace('T', ' ');
                var match = normalized.match(/^(\d{4})-(\d{2})-(\d{2})\s+(\d{2}):(\d{2})(?::(\d{2}))?$/);
                if (!match) {
                    return null;
                }
                var year = parseInt(match[1], 10);
                var month = parseInt(match[2], 10);
                var day = parseInt(match[3], 10);
                var hour = parseInt(match[4], 10);
                var minute = parseInt(match[5], 10);
                var second = parseInt(match[6] || '0', 10);

                return Math.floor(Date.UTC(year, month - 1, day, hour, minute, second) / 1000);
            }

            function getTodayStartTsUtc() {
                var now = new Date();
                now.setUTCHours(0, 0, 0, 0);

                return Math.floor(now.getTime() / 1000);
            }

            function resolveFormTemporalContext(form) {
                var startField = form.querySelector('[name="starts_at_utc"], [name$="[starts_at_utc]"], [name="parse_start_utc"], [name="zone_start_utc"]');
                var endField = form.querySelector('[name="ends_at_utc"], [name$="[ends_at_utc]"], [name="parse_end_utc"], [name="zone_end_utc"]');
                if (!startField || !endField) {
                    return null;
                }

                var startRaw = String(startField.value || '').trim();
                var endRaw = String(endField.value || '').trim();
                var startTs = parseUtcInputToTs(startRaw);
                var endTs = parseUtcInputToTs(endRaw);
                if (startTs === null || endTs === null || endTs <= startTs) {
                    return null;
                }

                return {
                    startRaw: startRaw,
                    endRaw: endRaw,
                    startTs: startTs,
                    endTs: endTs
                };
            }

            function resolveDisplayCodeFromForm(form) {
                var displayField = form.querySelector('[name="display_code"], [name$="[row_code]"]');
                return displayField ? String(displayField.value || '').trim() : '';
            }

            function resolveImpactScopeFromForm(form) {
                var displayCode = resolveDisplayCodeFromForm(form);
                if (displayCode !== '') {
                    return {
                        display_code: displayCode,
                        reading_mode: '',
                        family: ''
                    };
                }

                // Parse Weather (zone/lunaison): scope explicite pour detecter les recouvrements reels.
                if (form.querySelector('[name="parse_start_utc"], [name="zone_start_utc"]')) {
                    return {
                        display_code: '',
                        reading_mode: 'SYM_Weather',
                        family: 'symbolic'
                    };
                }

                return {
                    display_code: '',
                    reading_mode: '',
                    family: ''
                };
            }

            function resolveLangFromForm(form) {
                var langField = form.querySelector('[name="lang"], [name$="[display_lang]"]');
                return langField ? String(langField.value || '').trim() : 'fr';
            }

            function resolveScheduleIdFromForm(form) {
                var action = String(form.getAttribute('action') || '');
                var match = action.match(/\/admin\/symbolic-text\/([^/]+)\/update(?:$|\?)/);
                if (!match || !match[1]) {
                    return '';
                }
                try {
                    return decodeURIComponent(match[1]);
                } catch (e) {
                    return match[1];
                }
            }

            function fillRetroConfirmModal(payload) {
                var rangeNode = retroConfirmModal.querySelector('[data-retro-range]');
                var daysNode = retroConfirmModal.querySelector('[data-retro-days]');
                var overlapSummaryNode = retroConfirmModal.querySelector('[data-retro-overlap-summary]');
                var overlapListNode = retroConfirmModal.querySelector('[data-retro-overlap-list]');
                if (!rangeNode || !daysNode || !overlapSummaryNode || !overlapListNode) {
                    return;
                }

                rangeNode.textContent = String(payload.start_utc || 'n/a') + ' -> ' + String(payload.end_utc || 'n/a');

                var days = Array.isArray(payload.days_concerned) ? payload.days_concerned : [];
                var pastDays = Array.isArray(payload.past_days) ? payload.past_days : [];
                if (days.length === 0) {
                    daysNode.textContent = 'n/a';
                } else if (pastDays.length === 0) {
                    daysNode.textContent = days.join(', ');
                } else {
                    daysNode.textContent = days.join(', ') + ' (jours passes: ' + pastDays.join(', ') + ')';
                }

                var overlaps = Array.isArray(payload.overlaps) ? payload.overlaps : [];
                if (!payload.would_rewrite || overlaps.length === 0) {
                    overlapSummaryNode.textContent = 'Aucun recouvrement detecte. Aucune reecriture de donnees existantes.';
                    overlapListNode.innerHTML = '';
                    return;
                }

                overlapSummaryNode.textContent = String(payload.overlap_count || overlaps.length) + ' recouvrement(s) detecte(s). Une reecriture est probable.';
                overlapListNode.innerHTML = overlaps.map(function (item) {
                    var label = String(item && item.label ? item.label : 'Texte existant');
                    var start = String(item && item.starts_at_utc ? item.starts_at_utc : 'n/a');
                    var end = String(item && item.ends_at_utc ? item.ends_at_utc : 'n/a');
                    var id = String(item && item.schedule_id ? item.schedule_id : '');
                    return '<li><strong>' + escapeHtmlLocal(label) + '</strong>'
                        + ' [' + escapeHtmlLocal(start) + ' -> ' + escapeHtmlLocal(end) + ']'
                        + (id ? ' (#' + escapeHtmlLocal(id) + ')' : '')
                        + '</li>';
                }).join('');
            }

            function submitFormHard(form, extraFields) {
                if (!form) {
                    return;
                }

                var hardForm = document.createElement('form');
                hardForm.method = String(form.getAttribute('method') || 'post').toLowerCase();
                hardForm.action = String(form.getAttribute('action') || window.location.href);
                hardForm.style.display = 'none';

                var fields = form.querySelectorAll('input, select, textarea');
                fields.forEach(function (field) {
                    if (!(field instanceof HTMLElement)) {
                        return;
                    }
                    var name = field.getAttribute('name');
                    if (!name) {
                        return;
                    }

                    var tag = field.tagName.toLowerCase();
                    if (tag === 'input') {
                        var input = field;
                        var type = String(input.getAttribute('type') || 'text').toLowerCase();
                        if ((type === 'checkbox' || type === 'radio') && !input.checked) {
                            return;
                        }
                        if (type === 'file') {
                            return;
                        }
                    }

                    var hidden = document.createElement('input');
                    hidden.type = 'hidden';
                    hidden.name = name;
                    hidden.value = String(field.value || '');
                    hardForm.appendChild(hidden);
                });

                // Injection de champs additionnels (ex: autorisation retroactive).
                if (extraFields && typeof extraFields === 'object') {
                    Object.keys(extraFields).forEach(function (key) {
                        if (!key) {
                            return;
                        }
                        var hiddenExtra = document.createElement('input');
                        hiddenExtra.type = 'hidden';
                        hiddenExtra.name = String(key);
                        hiddenExtra.value = String(extraFields[key] || '');
                        hardForm.appendChild(hiddenExtra);
                    });
                }

                document.body.appendChild(hardForm);
                hardForm.submit();
            }

            function openRetroConfirmForForm(form, context) {
                if (!impactCheckUrl || !impactCheckToken) {
                    submitFormHard(form, { allow_retroactive_write: '1' });
                    return;
                }

                var requestPayload = {
                    _token: impactCheckToken,
                    start_utc: context.startRaw,
                    end_utc: context.endRaw,
                    lang: resolveLangFromForm(form),
                    schedule_id: resolveScheduleIdFromForm(form)
                };
                var impactScope = resolveImpactScopeFromForm(form);
                requestPayload.display_code = impactScope.display_code;
                requestPayload.reading_mode = impactScope.reading_mode;
                requestPayload.family = impactScope.family;

                fetch(impactCheckUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify(requestPayload)
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('impact check failed');
                        }
                        return response.json();
                    })
                    .then(function (payload) {
                        fillRetroConfirmModal(payload || {});
                        pendingRetroForm = form;
                        openModal(retroConfirmModal);
                    })
                    .catch(function () {
                        window.alert('Impossible de verifier l impact de la modification retroactive.');
                    });
            }

            function shouldGuardRetroactiveForm(form) {
                if (!form || !form.matches) {
                    return false;
                }
                return form.matches('[data-create-form], [data-edit-form], [data-weather-zone-form], .symbolic-parse-form');
            }

            function populateWeatherVariantSelect(phaseIndex, preferredVariantNo) {
                var variantSelect = weatherZoneModal.querySelector('[data-weather-zone-variant]');
                if (!variantSelect) {
                    return;
                }
                var options = weatherVariantsByPhase[phaseIndex] || [];
                var html = '';
                if (!options.length) {
                    html = '<option value="">Aucune variante validee/usee</option>';
                    variantSelect.innerHTML = html;
                    return;
                }
                options.forEach(function (item) {
                    var text = 'Variante ' + String(item.variant_no);
                    if (item.label) {
                        text += ' - ' + item.label;
                    }
                    html += '<option value="' + escapeHtmlLocal(item.variant_no) + '">' + escapeHtmlLocal(text) + '</option>';
                });
                variantSelect.innerHTML = html;

                if (typeof preferredVariantNo === 'number' && preferredVariantNo > 0) {
                    variantSelect.value = String(preferredVariantNo);
                    if (variantSelect.value !== String(preferredVariantNo)) {
                        variantSelect.selectedIndex = 0;
                    }
                } else {
                    variantSelect.selectedIndex = 0;
                }
            }

            function openWeatherZoneModal(trigger) {
                var zoneStart = trigger.getAttribute('data-zone-start') || '';
                var zoneEnd = trigger.getAttribute('data-zone-end') || '';
                var phaseRaw = trigger.getAttribute('data-phase-index') || trigger.getAttribute('data-phase-key') || '';
                var defaultPhase = parsePhaseIndex(phaseRaw);

                var startInput = weatherZoneModal.querySelector('[data-weather-zone-start]');
                var endInput = weatherZoneModal.querySelector('[data-weather-zone-end]');
                var phaseSelect = weatherZoneModal.querySelector('[data-weather-zone-phase]');
                var rangeNode = weatherZoneModal.querySelector('[data-weather-zone-range]');
                if (!startInput || !endInput || !phaseSelect || !rangeNode) {
                    return;
                }

                startInput.value = zoneStart;
                endInput.value = zoneEnd;
                rangeNode.textContent = zoneStart + ' -> ' + zoneEnd;

                if (defaultPhase === null) {
                    defaultPhase = 0;
                }
                phaseSelect.value = String(defaultPhase);
                if (phaseSelect.value !== String(defaultPhase)) {
                    phaseSelect.selectedIndex = 0;
                }
                populateWeatherVariantSelect(parseInt(phaseSelect.value, 10), null);
                openModal(weatherZoneModal);
            }

            document.addEventListener('click', function (event) {
                var closeButton = event.target.closest('[data-modal-close]');
                if (closeButton) {
                    event.preventDefault();
                    closeAllModals();
                    return;
                }
                var retroCancelButton = event.target.closest('[data-retro-cancel]');
                if (retroCancelButton) {
                    event.preventDefault();
                    pendingRetroForm = null;
                    closeModal(retroConfirmModal);
                    return;
                }
                var retroConfirmButton = event.target.closest('[data-retro-confirm]');
                if (retroConfirmButton) {
                    event.preventDefault();
                    if (!pendingRetroForm) {
                        closeModal(retroConfirmModal);
                        return;
                    }
                    var formToSubmit = pendingRetroForm;
                    pendingRetroForm = null;
                    closeModal(retroConfirmModal);
                    submitFormHard(formToSubmit, { allow_retroactive_write: '1' });
                    return;
                }

                var createTrigger = event.target.closest('[data-open-create]');
                if (createTrigger) {
                    event.preventDefault();
                    var createDisplay = createModal.querySelector('[data-create-row-code]') || createModal.querySelector('[data-create-display-code]');
                    var createStart = createModal.querySelector('[data-create-start]');
                    var createEnd = createModal.querySelector('[data-create-end]');
                    var createLabel = createModal.querySelector('[data-create-label]');
                    if (createDisplay) {
                        createDisplay.value = createTrigger.getAttribute('data-display-code') || createDisplay.value;
                    }
                    if (createStart) {
                        createStart.value = createTrigger.getAttribute('data-start') || '';
                    }
                    if (createEnd) {
                        createEnd.value = createTrigger.getAttribute('data-end') || '';
                    }
                    if (createLabel) {
                        createLabel.value = '';
                    }
                    openModal(createModal);
                    return;
                }

                var weatherZoneTrigger = event.target.closest('[data-open-weather-zone]');
                if (weatherZoneTrigger) {
                    event.preventDefault();
                    openWeatherZoneModal(weatherZoneTrigger);
                    return;
                }

                var editTrigger = event.target.closest('[data-open-edit]');
                if (editTrigger) {
                    event.preventDefault();
                    var id = editTrigger.getAttribute('data-id') || '';
                    var updateForm = editModal.querySelector('[data-edit-form]');
                    var deleteForm = editModal.querySelector('[data-delete-form]');
                    if (!updateForm || !deleteForm || !id) {
                        return;
                    }

                    var updateTemplate = updateForm.getAttribute('data-update-action-template') || '';
                    var deleteTemplate = deleteForm.getAttribute('data-delete-action-template') || '';
                    updateForm.setAttribute('action', updateTemplate.replace('SCHEDULE_ID', encodeURIComponent(id)));
                    deleteForm.setAttribute('action', deleteTemplate.replace('SCHEDULE_ID', encodeURIComponent(id)));

                    var mapping = [
                        ['[data-edit-display-code]', 'data-display-code'],
                        ['[data-edit-label]', 'data-label'],
                        ['[data-edit-subtitle]', 'data-subtitle'],
                        ['[data-edit-color]', 'data-color'],
                        ['[data-edit-icon]', 'data-icon'],
                        ['[data-edit-start]', 'data-start'],
                        ['[data-edit-end]', 'data-end'],
                        ['[data-edit-priority]', 'data-priority'],
                        ['[data-edit-schedule-type]', 'data-schedule-type'],
                        ['[data-edit-status]', 'data-status'],
                        ['[data-edit-schema-version]', 'data-schema-version'],
                        ['[data-edit-comment]', 'data-comment'],
                        ['[data-edit-editorial-notes]', 'data-editorial-notes'],
                        ['[data-edit-payload-json]', 'data-payload-json']
                    ];

                    mapping.forEach(function (pair) {
                        var field = editModal.querySelector(pair[0]);
                        if (!field) {
                            return;
                        }
                        field.value = editTrigger.getAttribute(pair[1]) || '';
                    });

                    var updateToken = editModal.querySelector('[data-edit-update-token]');
                    var deleteToken = editModal.querySelector('[data-edit-delete-token]');
                    if (updateToken) {
                        updateToken.value = editTrigger.getAttribute('data-update-token') || '';
                    }
                    if (deleteToken) {
                        deleteToken.value = editTrigger.getAttribute('data-delete-token') || '';
                    }

                    var isPublished = editModal.querySelector('[data-edit-is-published]');
                    var isValidated = editModal.querySelector('[data-edit-is-validated]');
                    var isCurrent = editModal.querySelector('[data-edit-is-current]');
                    if (isPublished) {
                        isPublished.checked = (editTrigger.getAttribute('data-is-published') || '0') === '1';
                    }
                    if (isValidated) {
                        isValidated.checked = (editTrigger.getAttribute('data-is-validated') || '0') === '1';
                    }
                    if (isCurrent) {
                        isCurrent.checked = (editTrigger.getAttribute('data-is-current') || '0') === '1';
                    }

                    openModal(editModal);
                }
            });

            var phaseSelectNode = weatherZoneModal.querySelector('[data-weather-zone-phase]');
            if (phaseSelectNode) {
                phaseSelectNode.addEventListener('change', function () {
                    var phase = parseInt(phaseSelectNode.value || '0', 10);
                    populateWeatherVariantSelect(phase, null);
                });
            }

            document.addEventListener('submit', function (event) {
                var form = event.target;
                if (!(form instanceof HTMLFormElement) || !shouldGuardRetroactiveForm(form)) {
                    return;
                }

                var context = resolveFormTemporalContext(form);
                if (context === null) {
                    return;
                }

                var todayStartTs = getTodayStartTsUtc();
                if (context.startTs >= todayStartTs) {
                    return;
                }

                event.preventDefault();
                openRetroConfirmForForm(form, context);
            }, true);

            document.addEventListener('keydown', function (event) {
                if (event.key === 'Escape') {
                    closeAllModals();
                }
            });
        })();
    </script>
    <script>
        (function () {
            var timeline = document.querySelector('[data-timeline-wheel]');
            if (!timeline) {
                return;
            }

            var apiUrl = timeline.getAttribute('data-api-url') || '';
            var bulkActiveUrl = timeline.getAttribute('data-toggle-active-url') || '';
            var bulkActiveToken = timeline.getAttribute('data-toggle-active-token') || '';
            var bulkSaveButton = document.querySelector('[data-bulk-save]');
            var bulkCountNode = document.querySelector('[data-bulk-count]');
            var span = timeline.getAttribute('data-span') || '2j';
            var spanSeconds = parseInt(timeline.getAttribute('data-span-seconds') || '172800', 10);
            var lang = timeline.getAttribute('data-lang') || 'fr';
            var showAll = (timeline.getAttribute('data-show-all') || '0') === '1';
            var endTs = parseInt(timeline.getAttribute('data-window-end-ts') || '0', 10);
            if (!apiUrl || !spanSeconds || !endTs) {
                return;
            }

            var chunkSeconds = 30 * 86400;
            var maxCacheSeconds = 180 * 86400;
            var preloadThreshold = 30 * 86400;
            var moveSeconds = Math.max(600, Math.floor(spanSeconds / 6));
            var state = {
                span: span,
                lang: lang,
                showAll: showAll,
                spanSeconds: spanSeconds,
                visibleEndTs: endTs,
                visibleStartTs: endTs - spanSeconds,
                chunks: [],
                inFlight: {},
                selectedSymbolicKey: null,
                pendingActiveBySchedule: {},
                bulkSaving: false
            };
            var labelsPanel = document.querySelector('.symbolic-layout__labels');

            function formatUtc(ts) {
                var d = new Date(ts * 1000);
                var y = d.getUTCFullYear();
                var m = String(d.getUTCMonth() + 1).padStart(2, '0');
                var day = String(d.getUTCDate()).padStart(2, '0');
                var h = String(d.getUTCHours()).padStart(2, '0');
                var min = String(d.getUTCMinutes()).padStart(2, '0');
                return y + '-' + m + '-' + day + ' ' + h + ':' + min;
            }

            function formatUtcPrecise(ts) {
                var d = new Date(ts * 1000);
                var y = d.getUTCFullYear();
                var m = String(d.getUTCMonth() + 1).padStart(2, '0');
                var day = String(d.getUTCDate()).padStart(2, '0');
                var h = String(d.getUTCHours()).padStart(2, '0');
                var min = String(d.getUTCMinutes()).padStart(2, '0');
                var sec = String(d.getUTCSeconds()).padStart(2, '0');
                return y + '-' + m + '-' + day + ' ' + h + ':' + min + ':' + sec + ' UTC';
            }

            function formatUtcWithSeconds(ts) {
                var d = new Date(ts * 1000);
                var y = d.getUTCFullYear();
                var m = String(d.getUTCMonth() + 1).padStart(2, '0');
                var day = String(d.getUTCDate()).padStart(2, '0');
                var h = String(d.getUTCHours()).padStart(2, '0');
                var min = String(d.getUTCMinutes()).padStart(2, '0');
                var sec = String(d.getUTCSeconds()).padStart(2, '0');
                return y + '-' + m + '-' + day + ' ' + h + ':' + min + ':' + sec;
            }

            function parseInitialPayload() {
                var node = document.getElementById('symbolic-initial-payload');
                if (!node) {
                    return null;
                }
                try {
                    return JSON.parse(node.textContent || '{}');
                } catch (e) {
                    return null;
                }
            }

            function chunkKey(startTs, endTs) {
                return String(startTs) + ':' + String(endTs);
            }

            function addChunk(startTs, endTs, payload) {
                var key = chunkKey(startTs, endTs);
                for (var i = 0; i < state.chunks.length; i++) {
                    if (state.chunks[i].key === key) {
                        state.chunks[i].payload = payload;
                        return;
                    }
                }
                state.chunks.push({ key: key, startTs: startTs, endTs: endTs, payload: payload });
            }

            function hasChunk(startTs, endTs) {
                var key = chunkKey(startTs, endTs);
                return state.chunks.some(function (chunk) { return chunk.key === key; });
            }

            function alignChunkStart(ts) {
                return Math.floor(ts / chunkSeconds) * chunkSeconds;
            }

            function requestChunk(startTs, endTs, force) {
                var key = chunkKey(startTs, endTs);
                if (state.inFlight[key] || (!force && hasChunk(startTs, endTs))) {
                    return Promise.resolve();
                }
                state.inFlight[key] = true;

                var url = apiUrl
                    + '?start_utc=' + encodeURIComponent(formatUtc(startTs))
                    + '&end_utc=' + encodeURIComponent(formatUtc(endTs))
                    + '&lang=' + encodeURIComponent(state.lang)
                    + '&show_all=' + (state.showAll ? '1' : '0');
                return fetch(url, { credentials: 'same-origin' })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('fetch timeline failed');
                        }
                        return response.json();
                    })
                    .then(function (payload) {
                        addChunk(startTs, endTs, payload);
                    })
                    .catch(function () {
                        // no-op: la vue reste utilisable avec les chunks deja disponibles
                    })
                    .finally(function () {
                        delete state.inFlight[key];
                    });
            }

            function ensureChunksForRange(startTs, endTs, force) {
                var cursor = alignChunkStart(startTs);
                var requests = [];
                while (cursor < endTs) {
                    var chunkStart = cursor;
                    var chunkEnd = cursor + chunkSeconds;
                    requests.push(requestChunk(chunkStart, chunkEnd, !!force));
                    cursor = chunkEnd;
                }
                return Promise.all(requests);
            }

            function pruneCache() {
                var centerTs = Math.floor((state.visibleStartTs + state.visibleEndTs) / 2);
                // On conserve toujours les chunks qui couvrent la fenetre visible.
                // Le reste est deleste par proximite pour limiter la memoire.
                var required = [];
                var optional = [];
                state.chunks.forEach(function (chunk) {
                    if (overlaps(chunk.startTs, chunk.endTs, state.visibleStartTs, state.visibleEndTs)) {
                        required.push(chunk);
                    } else {
                        optional.push(chunk);
                    }
                });

                var withDistance = optional.map(function (chunk) {
                    var chunkCenter = Math.floor((chunk.startTs + chunk.endTs) / 2);
                    return { chunk: chunk, distance: Math.abs(chunkCenter - centerTs) };
                });
                withDistance.sort(function (a, b) { return a.distance - b.distance; });

                var kept = required.slice();
                var covered = required.reduce(function (sum, chunk) {
                    return sum + (chunk.endTs - chunk.startTs);
                }, 0);
                for (var i = 0; i < withDistance.length; i++) {
                    var candidate = withDistance[i].chunk;
                    if (covered + (candidate.endTs - candidate.startTs) > maxCacheSeconds && kept.length > 0) {
                        continue;
                    }
                    kept.push(candidate);
                    covered += (candidate.endTs - candidate.startTs);
                }
                state.chunks = kept;
            }

            function overlaps(startA, endA, startB, endB) {
                return startA < endB && endA > startB;
            }

            function readyStateClass(entry, fallbackStartTs, fallbackEndTs) {
                if (!entry || !entry.is_ready) {
                    return ' is-warning';
                }

                var endTs = typeof entry.end_ts === 'number' ? entry.end_ts : fallbackEndTs;
                if (typeof endTs !== 'number') {
                    return ' is-ready-upcoming';
                }

                var nowTs = Math.floor(Date.now() / 1000);
                if (endTs <= nowTs) {
                    return ' is-ready-past';
                }

                return ' is-ready-upcoming';
            }

            function escapeHtml(value) {
                return String(value)
                    .replace(/&/g, '&amp;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;')
                    .replace(/"/g, '&quot;')
                    .replace(/'/g, '&#039;');
            }

            function normalizeLooseBool(value) {
                if (typeof value === 'boolean') {
                    return value;
                }
                if (typeof value === 'number') {
                    return value !== 0;
                }
                if (typeof value === 'string') {
                    var normalized = value.trim().toLowerCase();
                    if (['1', 'true', 'yes', 'on'].indexOf(normalized) >= 0) {
                        return true;
                    }
                    if (['0', 'false', 'no', 'off'].indexOf(normalized) >= 0) {
                        return false;
                    }
                }

                return false;
            }

            function resolveEntrySnapshotActive(entry) {
                var scheduleId = String((entry && entry.id) || '').trim();
                if (scheduleId && Object.prototype.hasOwnProperty.call(state.pendingActiveBySchedule, scheduleId)) {
                    return !!state.pendingActiveBySchedule[scheduleId];
                }

                return normalizeLooseBool(entry ? entry.is_published_for_snapshot : false);
            }

            function buildPublishSwitchHtml(entry) {
                if (!state.showAll) {
                    return '';
                }
                var scheduleId = String((entry && entry.id) || '').trim();
                if (!scheduleId) {
                    return '';
                }
                var originalActive = normalizeLooseBool(entry ? entry.is_published_for_snapshot : false);
                var currentActive = resolveEntrySnapshotActive(entry);
                return '' +
                    '<label class="symbolic-publish-switch symbolic-publish-switch--compact" title="Publication snapshot (sw_display.is_active)">' +
                    '<input type="checkbox" class="symbolic-publish-switch__input" data-publish-toggle data-schedule-id="' + escapeHtml(scheduleId) + '" data-original-active="' + (originalActive ? '1' : '0') + '"' + (currentActive ? ' checked' : '') + '>' +
                    '<span class="symbolic-publish-switch__slider"></span>' +
                    '<span class="symbolic-publish-switch__label">' + (currentActive ? 'Publie' : 'Non publie') + '</span>' +
                    '</label>';
            }

            function pendingActiveCount() {
                return Object.keys(state.pendingActiveBySchedule).length;
            }

            function refreshBulkSaveUi() {
                if (!bulkSaveButton || !bulkCountNode) {
                    return;
                }
                var count = pendingActiveCount();
                bulkCountNode.textContent = String(count);
                bulkSaveButton.disabled = count === 0 || state.bulkSaving;
                bulkSaveButton.classList.toggle('is-pending', count > 0);
            }

            function reloadVisibleChunks() {
                state.chunks = [];
                state.inFlight = {};
                return ensureChunksForRange(state.visibleStartTs, state.visibleEndTs, true).then(function () {
                    renderFromCache();
                    maybePrefetch();
                });
            }

            function persistPendingActiveChanges() {
                if (!state.showAll || !bulkActiveUrl || !bulkActiveToken || state.bulkSaving) {
                    return;
                }
                var scheduleIds = Object.keys(state.pendingActiveBySchedule);
                if (!scheduleIds.length) {
                    refreshBulkSaveUi();
                    return;
                }

                var updates = scheduleIds.map(function (scheduleId) {
                    return {
                        schedule_id: scheduleId,
                        is_active: !!state.pendingActiveBySchedule[scheduleId]
                    };
                });

                state.bulkSaving = true;
                refreshBulkSaveUi();

                fetch(bulkActiveUrl, {
                    method: 'POST',
                    credentials: 'same-origin',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        _token: bulkActiveToken,
                        updates: updates
                    })
                })
                    .then(function (response) {
                        if (!response.ok) {
                            throw new Error('bulk active failed');
                        }
                        return response.json();
                    })
                    .then(function () {
                        state.pendingActiveBySchedule = {};
                        return reloadVisibleChunks();
                    })
                    .catch(function () {
                        window.alert('Echec de la sauvegarde des publications.');
                    })
                    .finally(function () {
                        state.bulkSaving = false;
                        refreshBulkSaveUi();
                    });
            }

            function positionPercent(ts) {
                var ratio = (ts - state.visibleStartTs) / Math.max(1, state.spanSeconds);
                return Math.max(0, Math.min(100, ratio * 100));
            }

            function widthPercent(startTs, endTs) {
                var width = ((endTs - startTs) / Math.max(1, state.spanSeconds)) * 100;
                return Math.max(0.65, width);
            }

            function buildDayLabel(ts) {
                var d = new Date(ts * 1000);
                if (state.span === '30j') {
                    var day2 = String(d.getUTCDate()).padStart(2, '0');
                    var month2 = String(d.getUTCMonth() + 1).padStart(2, '0');
                    var year2 = String(d.getUTCFullYear()).slice(-2);
                    return day2 + '/' + month2 + '/' + year2;
                }
                var days = ['Dimanche', 'Lundi', 'Mardi', 'Mercredi', 'Jeudi', 'Vendredi', 'Samedi'];
                var months = ['Janvier', 'Fevrier', 'Mars', 'Avril', 'Mai', 'Juin', 'Juillet', 'Aout', 'Septembre', 'Octobre', 'Novembre', 'Decembre'];
                return days[d.getUTCDay()] + ' ' + d.getUTCDate() + ' ' + months[d.getUTCMonth()];
            }

            function buildGridAndReal() {
                var grid = timeline.querySelector('[data-grid-lines]');
                var real = timeline.querySelector('[data-track-real]');
                if (!grid || !real) {
                    return;
                }

                var markers = [state.visibleStartTs];
                var cursorDate = new Date(state.visibleStartTs * 1000);
                cursorDate.setUTCHours(0, 0, 0, 0);
                if (Math.floor(cursorDate.getTime() / 1000) <= state.visibleStartTs) {
                    cursorDate.setUTCDate(cursorDate.getUTCDate() + 1);
                }
                while (Math.floor(cursorDate.getTime() / 1000) < state.visibleEndTs) {
                    markers.push(Math.floor(cursorDate.getTime() / 1000));
                    cursorDate.setUTCDate(cursorDate.getUTCDate() + 1);
                }
                markers.push(state.visibleEndTs);

                var nowDate = new Date();
                nowDate.setUTCHours(0, 0, 0, 0);
                var todayStartTs = Math.floor(nowDate.getTime() / 1000);
                var todayEndTs = todayStartTs + 86400;

                var todayColumnsHtml = [];
                for (var j = 0; j < markers.length - 1; j++) {
                    var daySegStart = markers[j];
                    var daySegEnd = markers[j + 1];
                    var highlightStart = Math.max(daySegStart, todayStartTs);
                    var highlightEnd = Math.min(daySegEnd, todayEndTs);
                    if (highlightEnd <= highlightStart) {
                        continue;
                    }
                    todayColumnsHtml.push(
                        '<span class="symbolic-grid__today-column" style="left:' + positionPercent(highlightStart) + '%;width:' + widthPercent(highlightStart, highlightEnd) + '%;"></span>'
                    );
                }

                var gridHtml = todayColumnsHtml.join('') + markers.map(function (ts) {
                    return '<span class="symbolic-grid__line" style="left:' + positionPercent(ts) + '%;"></span>';
                }).join('');
                grid.innerHTML = gridHtml;

                var realParts = [];
                for (var i = 0; i < markers.length - 1; i++) {
                    var segStart = markers[i];
                    var segEnd = markers[i + 1];
                    realParts.push(
                        '<div class="symbolic-real-cell" style="left:' + positionPercent(segStart) + '%;width:' + widthPercent(segStart, segEnd) + '%;">' +
                        escapeHtml(buildDayLabel(segStart)) +
                        '</div>'
                    );
                }
                real.innerHTML = realParts.join('');
            }

            function collectWindowData() {
                var astronomyMap = {};
                var symbolicMap = {};
                var lunationMap = {};
                var textSymbolicMap = {};
                var weatherEntriesMap = {};
                var entriesByRow = {};

                state.chunks.forEach(function (chunk) {
                    var payload = chunk.payload || {};

                    (payload.astronomy_points || []).forEach(function (point) {
                        if (!point || typeof point.ts !== 'number') {
                            return;
                        }
                        if (!overlaps(point.ts, point.ts + 1, state.visibleStartTs, state.visibleEndTs)) {
                            return;
                        }
                        astronomyMap[String(point.phase) + ':' + String(point.ts)] = point;
                    });

                    (payload.symbolic_segments || []).forEach(function (segment) {
                        if (!segment || typeof segment.full_start_ts !== 'number' || typeof segment.full_end_ts !== 'number') {
                            return;
                        }
                        if (!overlaps(segment.full_start_ts, segment.full_end_ts, state.visibleStartTs, state.visibleEndTs)) {
                            return;
                        }
                        symbolicMap[String(segment.full_start_ts) + ':' + String(segment.full_end_ts) + ':' + String(segment.label)] = segment;
                    });

                    (payload.lunation_segments || []).forEach(function (segment) {
                        if (!segment || typeof segment.full_start_ts !== 'number' || typeof segment.full_end_ts !== 'number') {
                            return;
                        }
                        if (!overlaps(segment.full_start_ts, segment.full_end_ts, state.visibleStartTs, state.visibleEndTs)) {
                            return;
                        }
                        lunationMap[String(segment.full_start_ts) + ':' + String(segment.full_end_ts)] = segment;
                    });

                    (payload.text_symbolic_zones || []).forEach(function (zone) {
                        if (!zone || typeof zone.full_start_ts !== 'number' || typeof zone.full_end_ts !== 'number') {
                            return;
                        }
                        if (!overlaps(zone.full_start_ts, zone.full_end_ts, state.visibleStartTs, state.visibleEndTs)) {
                            return;
                        }
                        var zoneKey = String(zone.zone_key || (String(zone.full_start_ts) + ':' + String(zone.full_end_ts) + ':' + String(zone.label || '')));
                        textSymbolicMap[zoneKey] = zone;
                    });

                    (payload.weather_entries || []).forEach(function (entry) {
                        if (!entry || typeof entry.start_ts !== 'number' || typeof entry.end_ts !== 'number') {
                            return;
                        }
                        if (!overlaps(entry.start_ts, entry.end_ts, state.visibleStartTs, state.visibleEndTs)) {
                            return;
                        }
                        var weatherKey = String(entry.id || (String(entry.start_ts) + ':' + String(entry.end_ts))) + ':weather';
                        if (!weatherEntriesMap[weatherKey]) {
                            weatherEntriesMap[weatherKey] = entry;
                            return;
                        }
                        var existingWeather = weatherEntriesMap[weatherKey];
                        existingWeather.start_ts = Math.min(existingWeather.start_ts, entry.start_ts);
                        existingWeather.end_ts = Math.max(existingWeather.end_ts, entry.end_ts);
                    });

                    var payloadEntries = payload.entries_by_row || {};
                    Object.keys(payloadEntries).forEach(function (rowCode) {
                        if (!entriesByRow[rowCode]) {
                            entriesByRow[rowCode] = {};
                        }
                        payloadEntries[rowCode].forEach(function (entry) {
                            if (!entry || typeof entry.start_ts !== 'number' || typeof entry.end_ts !== 'number') {
                                return;
                            }
                            if (!overlaps(entry.start_ts, entry.end_ts, state.visibleStartTs, state.visibleEndTs)) {
                                return;
                            }
                            var key = String(entry.id || '') + ':' + rowCode;
                            if (!entriesByRow[rowCode][key]) {
                                entriesByRow[rowCode][key] = entry;
                                return;
                            }
                            var existing = entriesByRow[rowCode][key];
                            existing.start_ts = Math.min(existing.start_ts, entry.start_ts);
                            existing.end_ts = Math.max(existing.end_ts, entry.end_ts);
                        });
                    });
                });

                var astronomy = Object.keys(astronomyMap).map(function (k) { return astronomyMap[k]; });
                astronomy.sort(function (a, b) { return a.ts - b.ts; });

                var symbolic = Object.keys(symbolicMap).map(function (k) { return symbolicMap[k]; });
                symbolic.sort(function (a, b) { return a.full_start_ts - b.full_start_ts; });

                var lunation = Object.keys(lunationMap).map(function (k) { return lunationMap[k]; });
                lunation.sort(function (a, b) { return a.full_start_ts - b.full_start_ts; });

                var textSymbolicZones = Object.keys(textSymbolicMap).map(function (k) { return textSymbolicMap[k]; });
                textSymbolicZones.sort(function (a, b) { return a.full_start_ts - b.full_start_ts; });

                var weatherEntries = Object.keys(weatherEntriesMap).map(function (k) { return weatherEntriesMap[k]; });
                weatherEntries.sort(function (a, b) { return a.start_ts - b.start_ts; });

                var normalizedEntriesByRow = {};
                Object.keys(entriesByRow).forEach(function (rowCode) {
                    var list = Object.keys(entriesByRow[rowCode]).map(function (k) { return entriesByRow[rowCode][k]; });
                    list.sort(function (a, b) { return a.start_ts - b.start_ts; });
                    normalizedEntriesByRow[rowCode] = list;
                });

                return {
                    astronomy: astronomy,
                    symbolic: symbolic,
                    lunation: lunation,
                    textSymbolicZones: textSymbolicZones,
                    weatherEntries: weatherEntries,
                    entriesByRow: normalizedEntriesByRow
                };
            }

            function renderAstronomy(points) {
                var track = timeline.querySelector('[data-track-astronomy]');
                if (!track) {
                    return;
                }
                if (!points.length) {
                    track.innerHTML = '<div class="symbolic-track__empty">Aucun evenement de phase dans cette fenetre.</div>';
                    return;
                }
                var html = points.map(function (point) {
                    return '' +
                        '<div class="symbolic-astro-point phase-' + escapeHtml(point.phase) + '" style="left:' + positionPercent(point.ts) + '%;">' +
                        '<span class="symbolic-astro-point__dot"></span>' +
                        '<span class="symbolic-astro-point__label">' + escapeHtml(point.label || '') + '</span>' +
                        '<span class="symbolic-astro-point__time">' + escapeHtml(point.time_label || '') + '</span>' +
                        '</div>';
                }).join('');
                track.innerHTML = html;
            }

            function renderLunation(segments) {
                var track = timeline.querySelector('[data-track-lunation]');
                if (!track) {
                    return;
                }
                if (!segments.length) {
                    track.innerHTML = '<div class="symbolic-track__empty">Lunaisons indisponibles dans cette fenetre.</div>';
                    return;
                }

                var html = segments.map(function (segment) {
                    var fullStartTs = typeof segment.full_start_ts === 'number' ? segment.full_start_ts : segment.start_ts;
                    var fullEndTs = typeof segment.full_end_ts === 'number' ? segment.full_end_ts : segment.end_ts;
                    var startTs = Math.max(fullStartTs, state.visibleStartTs);
                    var endTs = Math.min(fullEndTs, state.visibleEndTs);
                    if (endTs <= startTs) {
                        return '';
                    }
                    var title = (segment.label || 'Lune') + ' - ' + (segment.year || '') +
                        ' (' + formatUtcPrecise(fullStartTs) + ' -> ' + formatUtcPrecise(fullEndTs) + ')';
                    return '' +
                        '<div class="symbolic-lunation-segment" style="left:' + positionPercent(startTs) + '%;width:' + widthPercent(startTs, endTs) + '%;--lunation-color:' + escapeHtml(segment.color || '#2b78c2') + ';" title="' + escapeHtml(title) + '">' +
                        '<span>' + escapeHtml(segment.label || '') + '</span>' +
                        '</div>';
                }).join('');
                track.innerHTML = html || '<div class="symbolic-track__empty">Lunaisons indisponibles dans cette fenetre.</div>';
            }

            function renderSymbolic(segments) {
                var track = timeline.querySelector('[data-track-symbolic]');
                if (!track) {
                    return;
                }
                if (!segments.length) {
                    track.innerHTML = '<div class="symbolic-track__empty">Influence symbolique indisponible (orb_window influence_orb / midpoint_partition_v1 absent).</div>';
                    return;
                }
                var html = segments.map(function (segment) {
                    var fullStartTs = typeof segment.full_start_ts === 'number' ? segment.full_start_ts : segment.start_ts;
                    var fullEndTs = typeof segment.full_end_ts === 'number' ? segment.full_end_ts : segment.end_ts;
                    var startTs = Math.max(fullStartTs, state.visibleStartTs);
                    var endTs = Math.min(fullEndTs, state.visibleEndTs);
                    if (endTs <= startTs) {
                        return '';
                    }
                    var key = String(fullStartTs) + '-' + String(fullEndTs) + '-' + String(segment.label || '');
                    var selectedClass = state.selectedSymbolicKey === key ? ' is-selected' : '';
                    var phaseKey = String(segment.phase_key || '');
                    var phaseIndex = (function (raw) {
                        var value = String(raw || '').trim().toLowerCase();
                        if (/^\d+$/.test(value)) {
                            var numeric = parseInt(value, 10);
                            return (numeric >= 0 && numeric <= 7) ? numeric : '';
                        }
                        if (value.indexOf('phase_') === 0) {
                            var tail = parseInt(value.slice(6), 10);
                            return (!Number.isNaN(tail) && tail >= 0 && tail <= 7) ? tail : '';
                        }
                        var map = {
                            'new_moon': 0,
                            'waxing_crescent': 1,
                            'first_quarter': 2,
                            'waxing_gibbous': 3,
                            'full_moon': 4,
                            'waning_gibbous': 5,
                            'last_quarter': 6,
                            'waning_crescent': 7
                        };
                        return Object.prototype.hasOwnProperty.call(map, value) ? map[value] : '';
                    })(phaseKey);
                    return '' +
                        '<div class="symbolic-phase-band' + selectedClass + '" ' +
                        'data-symbolic-key="' + escapeHtml(key) + '" ' +
                        'data-phase-label="' + escapeHtml(segment.label || '') + '" ' +
                        'data-phase-start="' + String(fullStartTs) + '" ' +
                        'data-phase-end="' + String(fullEndTs) + '" ' +
                        'style="left:' + positionPercent(startTs) + '%;width:' + widthPercent(startTs, endTs) + '%;--phase-color:' + escapeHtml(segment.color || '#325a80') + ';">' +
                        '<span>' + escapeHtml(segment.label || '') + '</span>' +
                        '<button type="button" class="symbolic-gap-add symbolic-gap-add--zone" title="Parser cette zone Weather" data-open-weather-zone data-zone-start="' + escapeHtml(formatUtcWithSeconds(fullStartTs)) + '" data-zone-end="' + escapeHtml(formatUtcWithSeconds(fullEndTs)) + '" data-phase-key="' + escapeHtml(phaseKey) + '" data-phase-index="' + escapeHtml(phaseIndex) + '">+</button>' +
                        '</div>';
                }).join('');
                track.innerHTML = html || '<div class="symbolic-track__empty">Influence symbolique indisponible (orb_window influence_orb / midpoint_partition_v1 absent).</div>';
            }

            function renderWeatherParseLunations(segments) {
                var track = timeline.querySelector('[data-track-weather-parse]');
                if (!track) {
                    return;
                }

                var parseAction = track.getAttribute('data-parse-action') || '';
                var parseToken = track.getAttribute('data-parse-token') || '';
                if (!parseAction || !parseToken) {
                    track.innerHTML = '<div class="symbolic-track__empty">Parse indisponible.</div>';
                    return;
                }

                var html = '';
                (segments || []).forEach(function (segment) {
                    if (!segment || typeof segment.full_start_ts !== 'number' || typeof segment.full_end_ts !== 'number') {
                        return;
                    }
                    var fullStartTs = segment.full_start_ts;
                    var fullEndTs = segment.full_end_ts;
                    var visibleStart = Math.max(fullStartTs, state.visibleStartTs);
                    var visibleEnd = Math.min(fullEndTs, state.visibleEndTs);
                    if (visibleEnd <= visibleStart) {
                        return;
                    }

                    var buttonLabel = 'Parse ' + String(segment.label || 'Lunaison');
                    html += '' +
                        '<form method="post" action="' + escapeHtml(parseAction) + '" class="symbolic-parse-form symbolic-parse-week" style="left:' + positionPercent(visibleStart) + '%;width:' + widthPercent(visibleStart, visibleEnd) + '%;">' +
                        '<input type="hidden" name="_token" value="' + escapeHtml(parseToken) + '">' +
                        '<input type="hidden" name="parse_start_utc" value="' + escapeHtml(formatUtcWithSeconds(fullStartTs)) + '">' +
                        '<input type="hidden" name="parse_end_utc" value="' + escapeHtml(formatUtcWithSeconds(fullEndTs)) + '">' +
                        '<input type="hidden" name="span" value="' + escapeHtml(state.span) + '">' +
                        '<input type="hidden" name="end_utc" value="' + escapeHtml(formatUtc(state.visibleEndTs)) + '">' +
                        '<input type="hidden" name="lang" value="' + escapeHtml(state.lang) + '">' +
                        '<input type="hidden" name="show_all" value="' + (state.showAll ? '1' : '0') + '">' +
                        '<button type="submit" class="symbolic-parse-button" title="' + escapeHtml(buttonLabel) + '">' +
                        escapeHtml(buttonLabel) +
                        '</button>' +
                        '</form>';
                });

                track.innerHTML = html || '<div class="symbolic-track__empty">Aucune lunaison visible.</div>';
            }

            function renderWeatherRow(segments, entries) {
                var track = timeline.querySelector('[data-track-weather]');
                if (!track) {
                    return;
                }

                var normalizedSegments = (segments || []).map(function (segment) {
                    if (!segment || typeof segment.full_start_ts !== 'number' || typeof segment.full_end_ts !== 'number') {
                        return null;
                    }
                    if (!overlaps(segment.full_start_ts, segment.full_end_ts, state.visibleStartTs, state.visibleEndTs)) {
                        return null;
                    }
                    return segment;
                }).filter(Boolean);
                normalizedSegments.sort(function (a, b) {
                    return (a.full_start_ts - b.full_start_ts) || (a.full_end_ts - b.full_end_ts);
                });

                var clippedEntries = (entries || []).map(function (entry) {
                    if (!entry || typeof entry.start_ts !== 'number' || typeof entry.end_ts !== 'number') {
                        return null;
                    }
                    if (!state.showAll && !resolveEntrySnapshotActive(entry)) {
                        return null;
                    }
                    var startTs = Math.max(entry.start_ts, state.visibleStartTs);
                    var endTs = Math.min(entry.end_ts, state.visibleEndTs);
                    if (endTs <= startTs) {
                        return null;
                    }
                    return {
                        source: entry,
                        startTs: startTs,
                        endTs: endTs
                    };
                }).filter(Boolean);
                clippedEntries.sort(function (a, b) {
                    return (a.startTs - b.startTs) || (a.endTs - b.endTs);
                });

                var html = '';
                var missingSegments = [];
                normalizedSegments.forEach(function (zone) {
                    var zoneStart = zone.full_start_ts;
                    var zoneEnd = zone.full_end_ts;
                    var visibleStart = Math.max(zoneStart, state.visibleStartTs);
                    var visibleEnd = Math.min(zoneEnd, state.visibleEndTs);
                    if (visibleEnd <= visibleStart) {
                        return;
                    }
                    var hasEntry = clippedEntries.some(function (entry) {
                        return overlaps(entry.startTs, entry.endTs, zoneStart, zoneEnd);
                    });
                    if (!hasEntry) {
                        missingSegments.push({
                            start_ts: visibleStart,
                            end_ts: visibleEnd
                        });
                    }
                });

                function phaseNameFr(phaseKey) {
                    var map = {
                        0: 'Nouvelle lune',
                        1: 'Premier croissant',
                        2: 'Premier quartier',
                        3: 'Gibbeuse croissante',
                        4: 'Pleine lune',
                        5: 'Gibbeuse decroissante',
                        6: 'Dernier quartier',
                        7: 'Dernier croissant'
                    };
                    return Object.prototype.hasOwnProperty.call(map, phaseKey) ? map[phaseKey] : 'Phase inconnue';
                }

                function normalizePhaseKey(raw) {
                    var value = String(raw || '').trim().toLowerCase();
                    if (/^\d+$/.test(value)) {
                        var n = parseInt(value, 10);
                        return (n >= 0 && n <= 7) ? n : null;
                    }
                    if (value.indexOf('phase_') === 0) {
                        var tail = parseInt(value.slice(6), 10);
                        return (!Number.isNaN(tail) && tail >= 0 && tail <= 7) ? tail : null;
                    }
                    var map = {
                        'new_moon': 0,
                        'waxing_crescent': 1,
                        'first_quarter': 2,
                        'waxing_gibbous': 3,
                        'full_moon': 4,
                        'waning_gibbous': 5,
                        'last_quarter': 6,
                        'waning_crescent': 7
                    };
                    return Object.prototype.hasOwnProperty.call(map, value) ? map[value] : null;
                }

                function positiveIntOrNull(raw) {
                    var value = String(raw || '').trim();
                    if (!/^\d+$/.test(value)) {
                        return null;
                    }
                    var n = parseInt(value, 10);
                    return n > 0 ? n : null;
                }

                function normalizeBool(value) {
                    if (typeof value === 'boolean') {
                        return value;
                    }
                    if (typeof value === 'number') {
                        return value !== 0;
                    }
                    if (typeof value === 'string') {
                        var normalized = value.trim().toLowerCase();
                        if (['1', 'true', 'yes', 'on'].indexOf(normalized) >= 0) {
                            return true;
                        }
                        if (['0', 'false', 'no', 'off'].indexOf(normalized) >= 0) {
                            return false;
                        }
                    }
                    return null;
                }

                function boolLabel(value) {
                    if (value === true) {
                        return 'true';
                    }
                    if (value === false) {
                        return 'false';
                    }
                    return 'n/a';
                }

                function parsePayloadJson(raw) {
                    if (typeof raw !== 'string' || raw.trim() === '') {
                        return null;
                    }
                    try {
                        var parsed = JSON.parse(raw);
                        return (parsed && typeof parsed === 'object') ? parsed : null;
                    } catch (e) {
                        return null;
                    }
                }

                function extractWeatherMeta(entry) {
                    var meta = (entry && entry.symbolic_weather && typeof entry.symbolic_weather === 'object') ? entry.symbolic_weather : {};
                    var payload = parsePayloadJson(entry.payload_json || '');

                    var phaseKey = normalizePhaseKey(meta.phase_key);
                    if (phaseKey === null) {
                        phaseKey = normalizePhaseKey(entry.phase_key);
                    }
                    if (phaseKey === null && payload) {
                        phaseKey = normalizePhaseKey(payload.phase_key || payload.orb_phase_key);
                    }

                    var variantNo = positiveIntOrNull(meta.variant_no);
                    if (variantNo === null) {
                        variantNo = positiveIntOrNull(entry.variant_no);
                    }
                    if (variantNo === null && payload) {
                        variantNo = positiveIntOrNull(payload.variant_no);
                    }

                    var variantId = String(meta.variant_id || entry.variant_id || (payload ? (payload.variant_id || '') : '') || '').trim();
                    var isValidated = normalizeBool(meta.is_validated);
                    if (isValidated === null && payload) {
                        isValidated = normalizeBool(payload.is_validated);
                    }
                    var isUsed = normalizeBool(meta.is_used);
                    if (isUsed === null && payload) {
                        isUsed = normalizeBool(payload.is_used);
                    }

                    return {
                        phaseKey: phaseKey,
                        variantNo: variantNo,
                        variantId: variantId,
                        isValidated: isValidated,
                        isUsed: isUsed
                    };
                }

                clippedEntries.forEach(function (entryPack) {
                    var entry = entryPack.source || {};
                    var meta = extractWeatherMeta(entry);
                    var phaseLabel = meta.phaseKey === null ? 'n/a' : (String(meta.phaseKey) + ' (' + phaseNameFr(meta.phaseKey) + ')');
                    var variantNoLabel = meta.variantNo === null ? 'n/a' : String(meta.variantNo);
                    var variantIdLabel = meta.variantId !== '' ? meta.variantId : 'n/a';
                    var metaLine = 'phase_key: ' + phaseLabel
                        + ' | variant_no: ' + variantNoLabel
                        + ' | variant_id: ' + variantIdLabel
                        + ' | is_validated: ' + boolLabel(meta.isValidated)
                        + ' | is_used: ' + boolLabel(meta.isUsed);
                    if (!state.showAll && resolveEntrySnapshotActive(entry)) {
                        metaLine += ' | publie';
                    }

                    var weatherReadyClass = readyStateClass(entry, entryPack.startTs, entryPack.endTs);
                    html += '' +
                        '<article class="symbolic-text-entry symbolic-text-entry--weather' + weatherReadyClass + '" style="left:' + positionPercent(entryPack.startTs) + '%;width:' + widthPercent(entryPack.startTs, entryPack.endTs) + '%;--entry-color:#2D66A0;">' +
                        '<div class="symbolic-text-entry__text symbolic-text-entry__text--weather">' +
                        '<div class="symbolic-weather-body">' + escapeHtml(entry.label || '') + '</div>' +
                        '<small class="symbolic-weather-meta">' + escapeHtml(metaLine) + '</small>' +
                        buildPublishSwitchHtml(entry) +
                        '</div>' +
                        '</article>';
                });

                missingSegments.forEach(function (segment) {
                    if (!segment || segment.end_ts <= segment.start_ts) {
                        return;
                    }
                    html += '' +
                        '<div class="symbolic-text-problem symbolic-text-problem--weather-missing" style="left:' + positionPercent(segment.start_ts) + '%;width:' + widthPercent(segment.start_ts, segment.end_ts) + '%;" title="Texte Weather manquant pour cette zone">' +
                        '<span>TEXTE MANQUANT</span>' +
                        '</div>';
                });

                if (!clippedEntries.length) {
                    html += '<div class="symbolic-track__empty symbolic-track__empty--warning">! Donnee Weather manquante</div>';
                }
                track.innerHTML = html;
            }

            function formatUtcInput(ts) {
                return formatUtc(ts);
            }

            function buildEditButtonHtml(entry, rowCode) {
                return '' +
                    '<button type="button" class="symbolic-entry__edit" data-open-edit' +
                    ' data-id="' + escapeHtml(entry.id || '') + '"' +
                    ' data-display-code="' + escapeHtml(rowCode || '') + '"' +
                    ' data-label="' + escapeHtml(entry.label || '') + '"' +
                    ' data-subtitle="' + escapeHtml(entry.subtitle || '') + '"' +
                    ' data-color="' + escapeHtml(entry.color || '') + '"' +
                    ' data-icon="' + escapeHtml(entry.icon || '') + '"' +
                    ' data-start="' + escapeHtml(entry.start_at_input || formatUtcInput(entry.start_ts)) + '"' +
                    ' data-end="' + escapeHtml(entry.end_at_input || formatUtcInput(entry.end_ts)) + '"' +
                    ' data-priority="' + escapeHtml(entry.priority || 0) + '"' +
                    ' data-schedule-type="' + escapeHtml(entry.schedule_type || 'influence_window') + '"' +
                    ' data-status="' + escapeHtml(entry.status || 'validated') + '"' +
                    ' data-schema-version="' + escapeHtml(entry.schema_version || '1.0') + '"' +
                    ' data-comment="' + escapeHtml(entry.comment || '') + '"' +
                    ' data-editorial-notes="' + escapeHtml(entry.editorial_notes || '') + '"' +
                    ' data-payload-json="' + escapeHtml(entry.payload_json || '') + '"' +
                    ' data-is-published="' + (entry.is_published ? '1' : '0') + '"' +
                    ' data-is-validated="' + (entry.is_validated ? '1' : '0') + '"' +
                    ' data-is-current="' + (entry.is_current ? '1' : '0') + '"' +
                    ' data-update-token="' + escapeHtml(entry.update_token || '') + '"' +
                    ' data-delete-token="' + escapeHtml(entry.delete_token || '') + '"' +
                    '>Modifier</button>';
            }

            function detectSynodicZoneProblems(sortedZones) {
                var missing = [];
                var overlapsFound = [];
                if (!sortedZones.length) {
                    missing.push({
                        start_ts: state.visibleStartTs,
                        end_ts: state.visibleEndTs
                    });
                    return { missing: missing, overlaps: overlapsFound };
                }

                var cursor = state.visibleStartTs;
                sortedZones.forEach(function (zone) {
                    var zoneStart = typeof zone.full_start_ts === 'number' ? zone.full_start_ts : zone.start_ts;
                    var zoneEnd = typeof zone.full_end_ts === 'number' ? zone.full_end_ts : zone.end_ts;
                    var visibleStart = Math.max(zoneStart, state.visibleStartTs);
                    var visibleEnd = Math.min(zoneEnd, state.visibleEndTs);
                    if (visibleEnd <= visibleStart) {
                        return;
                    }

                    if (visibleStart > cursor) {
                        missing.push({
                            start_ts: cursor,
                            end_ts: visibleStart
                        });
                    }
                    if (visibleStart < cursor) {
                        var overlapEnd = Math.min(cursor, visibleEnd);
                        if (overlapEnd > visibleStart) {
                            overlapsFound.push({
                                start_ts: visibleStart,
                                end_ts: overlapEnd
                            });
                        }
                    }
                    cursor = Math.max(cursor, visibleEnd);
                });

                if (cursor < state.visibleEndTs) {
                    missing.push({
                        start_ts: cursor,
                        end_ts: state.visibleEndTs
                    });
                }

                return {
                    missing: missing,
                    overlaps: overlapsFound
                };
            }

            function packTimelineEntries(entries) {
                var rows = [];
                (entries || []).forEach(function (entry) {
                    var placed = false;
                    for (var i = 0; i < rows.length; i++) {
                        var row = rows[i];
                        var last = row[row.length - 1];
                        if (entry.startTs >= last.endTs) {
                            row.push(entry);
                            placed = true;
                            break;
                        }
                    }
                    if (!placed) {
                        rows.push([entry]);
                    }
                });
                return rows;
            }

            function utcDayKey(ts) {
                var d = new Date(ts * 1000);
                var y = d.getUTCFullYear();
                var m = String(d.getUTCMonth() + 1).padStart(2, '0');
                var day = String(d.getUTCDate()).padStart(2, '0');
                return y + '-' + m + '-' + day;
            }

            function renderSynodic(zones, entries) {
                var track = timeline.querySelector('[data-track-synodic]');
                if (!track) {
                    return;
                }

                var normalizedZones = (zones || []).map(function (zone) {
                    if (!zone || typeof zone.full_start_ts !== 'number' || typeof zone.full_end_ts !== 'number') {
                        return null;
                    }
                    if (!overlaps(zone.full_start_ts, zone.full_end_ts, state.visibleStartTs, state.visibleEndTs)) {
                        return null;
                    }
                    return zone;
                }).filter(Boolean);
                normalizedZones.sort(function (a, b) {
                    return (a.full_start_ts - b.full_start_ts) || (a.full_end_ts - b.full_end_ts);
                });

                var clippedEntries = (entries || []).map(function (entry) {
                    if (!entry || typeof entry.start_ts !== 'number' || typeof entry.end_ts !== 'number') {
                        return null;
                    }
                    var startTs = Math.max(entry.start_ts, state.visibleStartTs);
                    var endTs = Math.min(entry.end_ts, state.visibleEndTs);
                    if (endTs <= startTs) {
                        return null;
                    }
                    return {
                        source: entry,
                        startTs: startTs,
                        endTs: endTs
                    };
                }).filter(Boolean);

                clippedEntries.sort(function (a, b) {
                    return (a.startTs - b.startTs) || (a.endTs - b.endTs);
                });

                var readyEntries = [];
                var pendingEntries = [];
                clippedEntries.forEach(function (entry) {
                    if (entry.source && entry.source.is_ready) {
                        readyEntries.push(entry);
                        return;
                    }
                    pendingEntries.push(entry);
                });

                var readyByDay = {};
                readyEntries.forEach(function (entry) {
                    var dayKey = utcDayKey(entry.source.start_ts || entry.startTs);
                    if (!readyByDay[dayKey]) {
                        readyByDay[dayKey] = [];
                    }
                    readyByDay[dayKey].push(entry);
                });

                var primaryReady = [];
                var overflowReady = [];
                var dayAlerts = [];
                Object.keys(readyByDay).sort().forEach(function (dayKey) {
                    var dayEntries = readyByDay[dayKey];
                    dayEntries.sort(function (a, b) {
                        return (a.startTs - b.startTs) || (a.endTs - b.endTs);
                    });
                    if (dayEntries.length > 0) {
                        primaryReady.push(dayEntries[0]);
                    }
                    if (dayEntries.length > 1) {
                        dayAlerts.push({
                            dayKey: dayKey,
                            count: dayEntries.length,
                            startTs: dayEntries[0].startTs,
                            endTs: dayEntries[dayEntries.length - 1].endTs
                        });
                        for (var i = 1; i < dayEntries.length; i++) {
                            overflowReady.push(dayEntries[i]);
                        }
                    }
                });

                primaryReady.sort(function (a, b) {
                    return (a.startTs - b.startTs) || (a.endTs - b.endTs);
                });

                var extraEntries = overflowReady.concat(pendingEntries);
                extraEntries.sort(function (a, b) {
                    return (a.startTs - b.startTs) || (a.endTs - b.endTs);
                });
                var packedExtraRows = packTimelineEntries(extraEntries);

                var entryRows = [primaryReady];
                packedExtraRows.forEach(function (rowEntries) {
                    entryRows.push(rowEntries);
                });
                var entryRowsCount = Math.max(1, entryRows.length);
                var layout = timeline.closest('.symbolic-layout');
                if (layout) {
                    layout.style.setProperty('--symbolic-synodic-extra-rows', String(entryRowsCount));
                }

                track.classList.remove('is-problem');

                var problems = detectSynodicZoneProblems(normalizedZones);
                var hasZoneProblem = !normalizedZones.length || problems.missing.length > 0 || problems.overlaps.length > 0;
                var hasValidationProblem = dayAlerts.length > 0;
                if (hasZoneProblem || hasValidationProblem) {
                    track.classList.add('is-problem');
                }

                var html = '<div class="symbolic-synodic-zones-row">';
                if (!normalizedZones.length) {
                    html += '<div class="symbolic-text-problem symbolic-text-problem--missing" style="left:0%;width:100%;">PROBLEME: aucune zone orb_window (midpoint_partition_v1)</div>';
                } else {
                    normalizedZones.forEach(function (zone) {
                        var fullStartTs = typeof zone.full_start_ts === 'number' ? zone.full_start_ts : zone.start_ts;
                        var fullEndTs = typeof zone.full_end_ts === 'number' ? zone.full_end_ts : zone.end_ts;
                        var startTs = Math.max(fullStartTs, state.visibleStartTs);
                        var endTs = Math.min(fullEndTs, state.visibleEndTs);
                        if (endTs <= startTs) {
                            return;
                        }

                        var tone = zone.tone || 'shade-1';
                        var title = (zone.label || '') + ' (' + formatUtcPrecise(fullStartTs) + ' -> ' + formatUtcPrecise(fullEndTs) + ')';
                        html += '' +
                            '<div class="symbolic-synodic-zone symbolic-text-zone symbolic-text-zone--' + escapeHtml(tone) + '" style="left:' + positionPercent(startTs) + '%;width:' + widthPercent(startTs, endTs) + '%;" title="' + escapeHtml(title) + '">' +
                            '<span class="symbolic-text-zone__label">' + escapeHtml(zone.label || '') + '</span>' +
                            '<button type="button" class="symbolic-gap-add symbolic-gap-add--zone" title="Ajouter un texte" data-open-create data-display-code="influence_synodic" data-schedule-type="influence_window" data-start="' + escapeHtml(formatUtcWithSeconds(fullStartTs)) + '" data-end="' + escapeHtml(formatUtcWithSeconds(fullEndTs)) + '">+</button>' +
                            '</div>';
                    });
                }

                problems.missing.forEach(function (segment) {
                    if (!segment || segment.end_ts <= segment.start_ts) {
                        return;
                    }
                    html += '' +
                        '<div class="symbolic-text-problem symbolic-text-problem--missing" style="left:' + positionPercent(segment.start_ts) + '%;width:' + widthPercent(segment.start_ts, segment.end_ts) + '%;" title="PROBLEME: zone manquante">' +
                        '<span>PROBLEME</span>' +
                        '</div>';
                });
                problems.overlaps.forEach(function (segment) {
                    if (!segment || segment.end_ts <= segment.start_ts) {
                        return;
                    }
                    html += '' +
                        '<div class="symbolic-text-problem symbolic-text-problem--overlap" style="left:' + positionPercent(segment.start_ts) + '%;width:' + widthPercent(segment.start_ts, segment.end_ts) + '%;" title="PROBLEME: chevauchement de zones">' +
                        '<span>CHEVAUCHEMENT</span>' +
                        '</div>';
                });

                dayAlerts.forEach(function (alert) {
                    var centerTs = Math.floor((alert.startTs + alert.endTs) / 2);
                    html += '' +
                        '<div class="symbolic-synodic-entry-alert" style="left:' + positionPercent(centerTs) + '%;" title="PROBLEME: ' + escapeHtml(String(alert.count)) + ' textes valides le meme jour">!</div>';
                });

                html += '</div>';

                entryRows.forEach(function (rowEntries) {
                    html += '<div class="symbolic-text-entries-row symbolic-synodic-entries-row">';
                    rowEntries.forEach(function (entryPack) {
                        var entry = entryPack.source || {};
                        var readyClass = readyStateClass(entry, entryPack.startTs, entryPack.endTs);
                        html += '' +
                            '<article class="symbolic-text-entry' + readyClass + '" style="left:' + positionPercent(entryPack.startTs) + '%;width:' + widthPercent(entryPack.startTs, entryPack.endTs) + '%;--entry-color:' + escapeHtml(entry.color || '#315A7B') + ';">' +
                            '<div class="symbolic-text-entry__text">' +
                            '<strong>' + escapeHtml(entry.label || '') + '</strong>' +
                            (entry.subtitle ? '<small>' + escapeHtml(entry.subtitle) + '</small>' : '') +
                            '</div>' +
                            buildPublishSwitchHtml(entry) +
                            buildEditButtonHtml(entry, 'influence_synodic') +
                            '</article>';
                    });
                    html += '</div>';
                });

                track.innerHTML = html;
            }

            function renderRows(entriesByRow) {
                var rows = timeline.querySelectorAll('[data-track-row]');
                rows.forEach(function (rowNode) {
                    var rowCode = rowNode.getAttribute('data-track-row') || '';
                    var rowScheduleType = rowNode.getAttribute('data-row-schedule-type') || 'influence_window';
                    var entries = entriesByRow[rowCode] || [];
                    var html = '';

                    if (!entries.length) {
                        html += '<div class="symbolic-track__empty symbolic-track__empty--warning">! Donnee manquante sur cette ligne</div>';
                    }

                    var clipped = entries.map(function (entry) {
                        var startTs = Math.max(entry.start_ts, state.visibleStartTs);
                        var endTs = Math.min(entry.end_ts, state.visibleEndTs);
                        return {
                            source: entry,
                            startTs: startTs,
                            endTs: endTs
                        };
                    }).filter(function (entry) {
                        return entry.endTs > entry.startTs;
                    });

                    clipped.sort(function (a, b) { return a.startTs - b.startTs; });

                    var minGapSeconds = Math.max(900, Math.floor(state.spanSeconds / 160));
                    var cursor = state.visibleStartTs;
                    clipped.forEach(function (entry) {
                        if (entry.startTs - cursor >= minGapSeconds) {
                            var centerTs = cursor + Math.floor((entry.startTs - cursor) / 2);
                            html += '<button type="button" class="symbolic-gap-add" style="left:' + positionPercent(centerTs) + '%;" title="Ajouter un texte" data-open-create data-display-code="' + escapeHtml(rowCode) + '" data-schedule-type="' + escapeHtml(rowScheduleType) + '" data-start="' + escapeHtml(formatUtcInput(cursor)) + '" data-end="' + escapeHtml(formatUtcInput(entry.startTs)) + '">+</button>';
                        }
                        cursor = Math.max(cursor, entry.endTs);
                    });
                    if (state.visibleEndTs - cursor >= minGapSeconds) {
                        var centerTail = cursor + Math.floor((state.visibleEndTs - cursor) / 2);
                        html += '<button type="button" class="symbolic-gap-add" style="left:' + positionPercent(centerTail) + '%;" title="Ajouter un texte" data-open-create data-display-code="' + escapeHtml(rowCode) + '" data-schedule-type="' + escapeHtml(rowScheduleType) + '" data-start="' + escapeHtml(formatUtcInput(cursor)) + '" data-end="' + escapeHtml(formatUtcInput(state.visibleEndTs)) + '">+</button>';
                    }

                    clipped.forEach(function (entryPack) {
                        var entry = entryPack.source;
                        var startTs = entryPack.startTs;
                        var endTs = entryPack.endTs;
                        var readyClass = readyStateClass(entry, startTs, endTs);
                        html += '' +
                            '<article class="symbolic-entry' + readyClass + '" style="left:' + positionPercent(startTs) + '%;width:' + widthPercent(startTs, endTs) + '%;--entry-color:' + escapeHtml(entry.color || '#315A7B') + ';">' +
                            '<div class="symbolic-entry__text">' +
                            '<strong>' + escapeHtml(entry.label || '') + '</strong>' +
                            (entry.subtitle ? '<small>' + escapeHtml(entry.subtitle) + '</small>' : '') +
                            '</div>' +
                            buildPublishSwitchHtml(entry) +
                            buildEditButtonHtml(entry, rowCode) +
                            '</article>';
                    });

                    rowNode.innerHTML = html;
                });
            }

            function syncLabelGroupBand(groupKey, startRowKey, endRowKey) {
                if (!labelsPanel) {
                    return;
                }
                var band = labelsPanel.querySelector('[data-label-group="' + groupKey + '"]');
                var startLabel = labelsPanel.querySelector('[data-label-row="' + startRowKey + '"]');
                var endLabel = labelsPanel.querySelector('[data-label-row="' + endRowKey + '"]');
                if (!band || !startLabel || !endLabel) {
                    return;
                }

                var top = startLabel.offsetTop;
                var bottom = endLabel.offsetTop + endLabel.offsetHeight;
                if (bottom <= top) {
                    band.style.opacity = '0';
                    return;
                }

                band.style.opacity = '1';
                band.style.top = String(top) + 'px';
                band.style.height = String(bottom - top) + 'px';
            }

            function syncTimelineLabelHeights() {
                if (!labelsPanel) {
                    return;
                }

                var labelNodes = labelsPanel.querySelectorAll('[data-label-row]');
                labelNodes.forEach(function (labelNode) {
                    var rowId = labelNode.getAttribute('data-label-row') || '';
                    if (!rowId) {
                        return;
                    }
                    var trackNode = timeline.querySelector('[data-track-row-id="' + rowId + '"]');
                    if (!trackNode) {
                        return;
                    }

                    var measuredHeight = trackNode.getBoundingClientRect().height;
                    if (!Number.isFinite(measuredHeight) || measuredHeight <= 0) {
                        return;
                    }
                    labelNode.style.height = String(Math.ceil(measuredHeight)) + 'px';
                });

                syncLabelGroupBand('family-weather', 'family_symbolic', 'weather');
                syncLabelGroupBand('event-stack', 'event_group', 'appellation');
                syncLabelGroupBand('symbolic-all', 'family_symbolic', 'appellation');
            }

            function updateWindowLabels() {
                var label = document.querySelector('[data-window-label]');
                if (label) {
                    label.textContent = 'Fenetre UTC: ' + formatUtc(state.visibleStartTs) + ' -> ' + formatUtc(state.visibleEndTs);
                }
                document.querySelectorAll('[data-window-end-hidden]').forEach(function (input) {
                    input.value = formatUtc(state.visibleEndTs);
                });
                document.querySelectorAll('[data-window-lang-hidden]').forEach(function (input) {
                    input.value = state.lang;
                });
                document.querySelectorAll('[data-window-show-all-hidden]').forEach(function (input) {
                    input.value = state.showAll ? '1' : '0';
                });
                var url = "{{ path('admin_symbolic_text') }}"
                    + '?span=' + encodeURIComponent(state.span)
                    + '&end_utc=' + encodeURIComponent(formatUtc(state.visibleEndTs))
                    + '&lang=' + encodeURIComponent(state.lang)
                    + '&show_all=' + (state.showAll ? '1' : '0');
                window.history.replaceState({}, '', url);
            }

            function renderFromCache() {
                buildGridAndReal();
                var data = collectWindowData();
                renderAstronomy(data.astronomy);
                renderLunation(data.lunation);
                renderSymbolic(data.symbolic);
                renderWeatherParseLunations(data.lunation || []);
                renderWeatherRow(data.symbolic, data.weatherEntries || []);
                renderRows(data.entriesByRow);
                renderSynodic(data.textSymbolicZones || [], data.entriesByRow.influence_synodic || []);
                syncTimelineLabelHeights();
                updateWindowLabels();
                refreshBulkSaveUi();
            }

            function maybePrefetch() {
                ensureChunksForRange(state.visibleStartTs - preloadThreshold, state.visibleEndTs + preloadThreshold, false)
                    .then(function () {
                        pruneCache();
                        renderFromCache();
                    });
            }

            var initialPayload = parseInitialPayload();
            if (initialPayload && typeof initialPayload.window_start_ts === 'number' && typeof initialPayload.window_end_ts === 'number') {
                addChunk(initialPayload.window_start_ts, initialPayload.window_end_ts, initialPayload);
            }

            renderFromCache();
            ensureChunksForRange(state.visibleStartTs, state.visibleEndTs, false).then(function () {
                renderFromCache();
                maybePrefetch();
            });

            var todayButton = document.querySelector('[data-jump-today]');
            var phaseTooltip = document.createElement('div');
            phaseTooltip.className = 'symbolic-phase-tooltip is-hidden';
            document.body.appendChild(phaseTooltip);
            var wheelLocked = false;

            function shiftWindow(shiftSeconds) {
                state.visibleStartTs += shiftSeconds;
                state.visibleEndTs += shiftSeconds;
                renderFromCache();
                maybePrefetch();
            }

            if (todayButton) {
                todayButton.addEventListener('click', function () {
                    var nowTs = Math.floor(Date.now() / 1000);
                    state.visibleEndTs = nowTs;
                    state.visibleStartTs = nowTs - state.spanSeconds;
                    renderFromCache();
                    maybePrefetch();
                });
            }

            window.addEventListener('resize', function () {
                syncTimelineLabelHeights();
            });

            if (bulkSaveButton) {
                bulkSaveButton.addEventListener('click', function () {
                    persistPendingActiveChanges();
                });
            }

            timeline.addEventListener('change', function (event) {
                var target = event.target;
                if (!(target instanceof Element)) {
                    return;
                }
                var toggleNode = target.closest('[data-publish-toggle]');
                if (!toggleNode) {
                    return;
                }
                var scheduleId = String(toggleNode.getAttribute('data-schedule-id') || '').trim();
                if (!scheduleId) {
                    return;
                }
                var originalActive = (toggleNode.getAttribute('data-original-active') || '0') === '1';
                var currentActive = !!toggleNode.checked;
                if (currentActive === originalActive) {
                    delete state.pendingActiveBySchedule[scheduleId];
                } else {
                    state.pendingActiveBySchedule[scheduleId] = currentActive;
                }

                var switchNode = toggleNode.closest('.symbolic-publish-switch');
                var labelNode = switchNode ? switchNode.querySelector('.symbolic-publish-switch__label') : null;
                if (labelNode) {
                    labelNode.textContent = currentActive ? 'Publie' : 'Non publie';
                }
                refreshBulkSaveUi();
            });

            function hidePhaseTooltip() {
                phaseTooltip.classList.add('is-hidden');
            }

            function showPhaseTooltip(band, clientX, clientY) {
                var label = band.getAttribute('data-phase-label') || '';
                var phaseStart = parseInt(band.getAttribute('data-phase-start') || '0', 10);
                var phaseEnd = parseInt(band.getAttribute('data-phase-end') || '0', 10);
                if (!phaseStart || !phaseEnd) {
                    hidePhaseTooltip();
                    return;
                }
                phaseTooltip.innerHTML = '' +
                    '<strong>' + escapeHtml(label) + '</strong>' +
                    '<span>Debut: ' + escapeHtml(formatUtcPrecise(phaseStart)) + '</span>' +
                    '<span>Fin: ' + escapeHtml(formatUtcPrecise(phaseEnd)) + '</span>';
                phaseTooltip.style.left = (clientX + 14) + 'px';
                phaseTooltip.style.top = (clientY + 14) + 'px';
                phaseTooltip.classList.remove('is-hidden');
            }

            timeline.addEventListener('mousemove', function (event) {
                var band = event.target.closest('.symbolic-phase-band');
                if (!band) {
                    hidePhaseTooltip();
                    return;
                }
                showPhaseTooltip(band, event.clientX, event.clientY);
            });

            timeline.addEventListener('mouseleave', function () {
                hidePhaseTooltip();
            });

            document.addEventListener('click', function (event) {
                var band = event.target.closest('.symbolic-phase-band');
                if (band) {
                    state.selectedSymbolicKey = band.getAttribute('data-symbolic-key') || null;
                    renderFromCache();
                    return;
                }
                if (state.selectedSymbolicKey !== null) {
                    state.selectedSymbolicKey = null;
                    renderFromCache();
                }
            });

            timeline.addEventListener('wheel', function (event) {
                var delta = event.deltaX !== 0 ? event.deltaX : event.deltaY;
                if (!delta) {
                    return;
                }
                event.preventDefault();
                if (wheelLocked) {
                    return;
                }
                wheelLocked = true;
                var direction = delta > 0 ? 1 : -1;
                var multiplier = Math.min(4, Math.max(1, Math.floor(Math.abs(delta) / 120) + 1));
                var shift = moveSeconds * multiplier * direction;
                shiftWindow(shift);
                setTimeout(function () {
                    wheelLocked = false;
                }, 45);
            }, { passive: false });
        })();
    </script>
{% endblock %}
